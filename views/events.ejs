<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Events Portal | V.S.B. Engineering College</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- jsPDF loaded securely via Cloudflare CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap');
        
        * {
            cursor: none !important;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #03000a;
            color: #f3f4f6;
            overflow-x: hidden;
        }

        .heading-font {
            font-family: 'Orbitron', sans-serif;
        }

        /* Starfield background */
        #starfield {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* Custom Cosmic Cursor */
        .custom-cursor {
            width: 14px;
            height: 14px;
            background: #a855f7;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 10000;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 10px #a855f7, 0 0 20px #2563eb;
            transition: transform 0.08s ease-out;
        }

        .custom-cursor-trail {
            width: 6px;
            height: 6px;
            background: #2563eb;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%, -50%);
            opacity: 0.6;
            transition: transform 0.15s ease-out;
        }

        .galaxy-card {
            background: rgba(13, 8, 28, 0.85);
            border: 1px solid rgba(6, 182, 212, 0.2);
            backdrop-filter: blur(12px);
            transition: all 0.3s ease;
        }

        .galaxy-card:hover {
            border-color: rgba(6, 182, 212, 0.4);
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.15);
        }

        @media (max-width: 640px) {
            .custom-cursor, .custom-cursor-trail {
                display: none !important;
            }
            * {
                cursor: auto !important;
            }
        }
    </style>
</head>
<body class="p-4 sm:p-6 md:p-12 min-h-screen flex flex-col justify-between" data-logged-in="<%= !!user %>">

    <!-- Active Custom Cursor -->
    <div id="cursor-core" class="custom-cursor"></div>
    <div id="cursor-trail" class="custom-cursor-trail"></div>

    <!-- Cosmic Starfield Layer -->
    <canvas id="starfield"></canvas>

    <div class="max-w-6xl mx-auto w-full flex-grow relative z-30">
        <!-- Header Controls -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-4">
            <div>
                <a href="/" class="heading-font text-xs tracking-widest text-cyan-400 hover:text-cyan-300 block mb-2">← Back to Dashboard</a>
                <h1 class="heading-font text-3xl font-black text-white tracking-wider">
                    EVENTS PORTAL TERMINAL
                </h1>
                <p class="text-xs text-gray-400 mt-1">Official engineering symposiums, hackathons, and laboratory workshops</p>
            </div>
            <div class="flex items-center space-x-4">
                <span class="text-purple-300 font-mono text-xs font-semibold">SSO Node Secure</span>
                <a href="/logout" class="bg-red-950/40 border border-red-500/30 hover:bg-red-900/50 text-red-300 text-xs px-4 py-2 rounded-xl transition">Sign Out</a>
            </div>
        </div>

        <!-- Events Filter & Search Controls -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <h3 class="heading-font text-xl font-bold tracking-wider">Active Events</h3>
            
            <div class="flex flex-wrap items-center gap-3 text-xs font-mono">
                <button onclick="filterCategory('All')" class="category-filter-btn px-3 py-1.5 rounded-full border border-purple-500 text-purple-200 bg-purple-950/20 font-semibold">All</button>
                <button onclick="filterCategory('Hackathon')" class="category-filter-btn px-3 py-1.5 rounded-full border border-white/10 text-gray-400 hover:border-white/20">Hackathon</button>
                <button onclick="filterCategory('Symposium')" class="category-filter-btn px-3 py-1.5 rounded-full border border-white/10 text-gray-400 hover:border-white/20">Symposium</button>
                <button onclick="filterCategory('Workshop')" class="category-filter-btn px-3 py-1.5 rounded-full border border-white/10 text-gray-400 hover:border-white/20">Workshop</button>
            </div>
        </div>

        <div class="relative mb-12">
            <input id="search-input" oninput="searchEvents()" type="text" placeholder="Search events by title, topic, or keyword..." class="w-full bg-black/40 border border-white/5 rounded-2xl px-6 py-4 text-xs sm:text-sm focus:outline-none focus:border-purple-500 transition">
        </div>

        <!-- Events Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="events-grid">
            <% if (events && events.length > 0) { %>
                <% events.forEach(event => { %>
                    <article class="galaxy-card p-6 rounded-2xl flex flex-col justify-between h-96 event-card" data-category="<%= event.category %>">
                        <div>
                            <div class="flex justify-between items-center text-xs text-gray-500 mb-4 font-mono">
                                <span class="border border-cyan-500/20 text-cyan-300 bg-cyan-950/20 px-2 py-0.5 rounded-full"><%= event.category %></span>
                                <span><%= event.date %></span>
                            </div>
                            <h3 class="heading-font text-lg font-bold text-white mb-2 line-clamp-1 event-title"><%= event.title %></h3>
                            <p class="text-gray-400 text-xs leading-relaxed mb-6"><%= event.summary %></p>
                            
                            <div class="space-y-2 mb-6 text-xs text-gray-500 font-mono">
                                <div class="flex items-center space-x-2">
                                    <span class="text-cyan-400">📍</span>
                                    <span class="line-clamp-1"><%= event.location %></span>
                                </div>
                            </div>
                        </div>

                        <div class="flex space-x-3 pt-4 border-t border-white/5">
                            <button onclick="openDetailModal('<%= event.title %>', '<%= event.category %>', '<%= event.date %>', '<%= event.location %>', '<%= event.summary %>')" class="flex-1 py-2 bg-white/5 hover:bg-white/10 text-white rounded-xl text-xs font-semibold transition border border-white/5">
                                Details
                              </button>
                            <button onclick="openRegistrationModal('<%= event.title %>')" class="flex-1 py-2 bg-cyan-600 hover:bg-cyan-500 text-black rounded-xl text-xs font-semibold transition">
                                Register
                            </button>
                        </div>
                    </article>
                <% }) %>
            <% } else { %>
                <p class="text-gray-500 text-xs col-span-3">No active events inside database nodes.</p>
            <% } %>
        </div>
    </div>

    <!-- EVENT DETAILS MODAL -->
    <div id="detail-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm">
        <div class="w-full max-w-lg galaxy-card p-8 rounded-3xl relative">
            <button onclick="closeDetailModal()" class="absolute top-6 right-6 text-gray-400 hover:text-white">✕</button>
            <span id="modal-category" class="border border-purple-500/20 text-purple-300 bg-purple-950/20 px-2.5 py-0.5 rounded-full text-xs font-mono"></span>
            <h3 id="modal-title" class="heading-font text-2xl font-bold text-white mt-4 mb-2"></h3>
            <p id="modal-meta" class="text-xs text-gray-500 font-mono mb-6"></p>
            
            <h4 class="text-xs font-bold uppercase text-cyan-400 font-mono mb-2">SYNOPSIS</h4>
            <p id="modal-desc" class="text-gray-300 text-xs sm:text-sm leading-relaxed mb-6"></p>

            <button id="modal-action-btn" class="w-full py-3 bg-cyan-600 hover:bg-cyan-500 text-black rounded-xl text-sm font-semibold transition">
                Initiate Registration
            </button>
        </div>
    </div>

    <!-- EVENT REGISTRATION FORM MODAL -->
    <div id="register-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm">
        <div class="w-full max-w-md galaxy-card p-8 rounded-3xl relative">
            <button onclick="closeRegistrationModal()" class="absolute top-6 right-6 text-gray-400 hover:text-white">✕</button>
            <h3 class="heading-font text-xl font-bold text-white mb-2">EVENT REGISTRATION</h3>
            <p class="text-xs text-gray-400 mb-6">Registering for: <span id="register-target-name" class="text-cyan-400 font-semibold"></span></p>

            <form id="form-events-register" onsubmit="submitRegistration(event)" class="space-y-4 text-xs">
                <input type="hidden" id="register-event-field">
                <div>
                    <label class="block text-gray-400 font-mono mb-2">STUDENT NAME</label>
                    <input type="text" id="reg-name" required placeholder="enter your name" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-400 transition">
                </div>
                <div>
                    <label class="block text-gray-400 font-mono mb-2">EMAIL ADDRESS</label>
                    <input type="email" id="reg-email" required placeholder="enter your email" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-400 transition">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-400 font-mono mb-2">ACADEMIC YEAR</label>
                        <select id="reg-year" required class="w-full bg-[#110b24] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-400 transition">
                            <option value="1st year">1st year</option>
                            <option value="2nd year">2nd year</option>
                            <option value="3rd year">3rd year</option>
                            <option value="4th year">4th year</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-2">DEPARTMENT</label>
                        <select id="reg-dept" required class="w-full bg-[#110b24] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-400 transition">
                            <option value="CSE(AIML)">CSE(AIML)</option>
                            <option value="CSE">CSE</option>
                            <option value="IT">IT</option>
                            <option value="ECE">ECE</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-gray-400 font-mono mb-2">COLLEGE / INSTITUTION</label>
                    <input type="text" id="reg-college" required value="VSB Engineering College" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-400 transition">
                </div>
                <button type="submit" class="w-full py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-xl text-sm font-semibold transition mt-4">
                    Establish Registration Pass
                </button>
            </form>
        </div>
    </div>

    <!-- REGISTRATION SUCCESS PASS MODAL -->
    <div id="pass-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm">
        <div class="w-full max-w-md p-8 rounded-3xl relative galaxy-card border-cyan-500/30">
            <button onclick="closePassModal()" class="absolute top-6 right-6 text-gray-400 hover:text-white">✕</button>
            <div class="text-center mb-6">
                <span class="h-2 w-2 rounded-full bg-cyan-400 inline-block animate-ping mb-2"></span>
                <h3 class="heading-font text-xl font-bold text-white uppercase">Access Pass Verified</h3>
                <p class="text-xs text-gray-500 mt-1 font-mono">VSB AI &amp; ML Academic Registries</p>
            </div>

            <!-- Glowing Ticket Pass Node -->
            <div id="registration-success-pass" class="border border-cyan-500/20 p-6 rounded-2xl bg-black/50 text-xs sm:text-sm font-mono space-y-4 mb-6">
                <div class="flex justify-between items-center pb-3 border-b border-white/5">
                    <span id="pass-ticket-id" class="text-gray-500">ID: TKT-00000</span>
                    <span class="text-cyan-400 font-bold">VSB ACCESS</span>
                </div>
                <div>
                    <span class="text-gray-500 text-[10px] block">VISITOR NAME</span>
                    <span id="pass-name" class="text-white font-bold">Hemanth</span>
                </div>
                <div>
                    <span class="text-gray-500 text-[10px] block">EVENT TARGET</span>
                    <span id="pass-event-name" class="text-purple-300 font-bold">Cosmic Hackathon 2025</span>
                </div>
                <div class="grid grid-cols-2 gap-2 pt-2">
                    <div>
                        <span class="text-gray-500 text-[10px] block">DEPT</span>
                        <span id="pass-dept" class="text-white">CSE(AIML)</span>
                    </div>
                    <div>
                        <span class="text-gray-500 text-[10px] block">YEAR</span>
                        <span id="pass-year" class="text-white">3rd year</span>
                    </div>
                </div>
            </div>

            <div class="flex space-x-4">
                <button onclick="generatePdfTicket()" class="flex-1 py-3 bg-cyan-600 hover:bg-cyan-500 text-black rounded-xl text-sm font-semibold transition flex items-center justify-center space-x-2">
                    <span>Export PDF Pass</span>
                </button>
                <button onclick="closePassModal()" class="flex-1 py-3 bg-white/5 hover:bg-white/10 text-white rounded-xl text-sm font-semibold transition border border-white/5">
                    Done
                </button>
            </div>
        </div>
    </div>

    <!-- Global Footer -->
    <footer class="border-t border-white/5 py-8 text-center mt-24">
        <p class="text-[10px] text-gray-500 font-normal">V.S.B. Engineering College, Karur, Tamil Nadu, India.</p>
        <p class="text-[9px] text-gray-600 mt-1">&copy; 2025 VSB Department of AI &amp; ML. All Rights Reserved.</p>
    </footer>

    <!-- Interactive Client-side logic scripts -->
    <script>
        // Custom Cursor Logic
        const cursorCore = document.getElementById('cursor-core');
        const cursorTrail = document.getElementById('cursor-trail');

        document.addEventListener('mousemove', (e) => {
            cursorCore.style.left = `${e.clientX}px`;
            cursorCore.style.top = `${e.clientY}px`;
            setTimeout(() => {
                cursorTrail.style.left = `${e.clientX}px`;
                cursorTrail.style.top = `${e.clientY}px`;
            }, 45);
        });

        // Hover enlargements
        document.querySelectorAll('a, button, .galaxy-card').forEach(element => {
            element.addEventListener('mouseenter', () => {
                cursorCore.style.transform = 'translate(-50%, -50%) scale(1.6)';
                cursorCore.style.backgroundColor = '#06b6d4';
            });
            element.addEventListener('mouseleave', () => {
                cursorCore.style.transform = 'translate(-50%, -50%) scale(1)';
                cursorCore.style.backgroundColor = '#06b6d4';
            });
        });

        // Starfield Canvas Logic
        const canvas = document.getElementById('starfield');
        const ctx = canvas.getContext('2d');
        let stars = [];

        function resizeStars() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            initializeStarsArray();
        }

        function initializeStarsArray() {
            stars = [];
            const count = Math.floor((canvas.width * canvas.height) / 7500);
            for (let i = 0; i < count; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    radius: Math.random() * 1.5,
                    brightness: Math.random(),
                    speed: 0.05 + Math.random() * 0.08
                });
            }
        }

        function drawStarsFrame() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#03000a';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            stars.forEach(star => {
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 255, 255, ${star.brightness})`;
                ctx.fill();

                star.brightness += star.speed * (Math.random() - 0.5);
                if (star.brightness < 0.1) star.brightness = 0.1;
                if (star.brightness > 1) star.brightness = 1;
            });

            requestAnimationFrame(drawStarsFrame);
        }

        window.addEventListener('resize', resizeStars);
        resizeStars();
        drawStarsFrame();


        /* 
           ========================================================================
           DASHBOARD DIRECTORY CONTROLLERS (SEARCH & FILTER)
           ========================================================================
        */
        let currentFilter = 'All';

        function filterCategory(cat) {
            currentFilter = cat;
            
            // Adjust active styling of filter buttons
            document.querySelectorAll('.category-filter-btn').forEach(btn => {
                if (btn.innerText === cat) {
                    btn.className = "category-filter-btn px-3 py-1.5 rounded-full border border-purple-500 text-purple-200 bg-purple-950/20 font-semibold";
                } else {
                    btn.className = "category-filter-btn px-3 py-1.5 rounded-full border border-white/10 text-gray-400 hover:border-white/20";
                }
            });

            applyFilters();
        }

        function searchEvents() {
            applyFilters();
        }

        function applyFilters() {
            const query = document.getElementById('search-input').value.toLowerCase();
            const cards = document.querySelectorAll('.event-card');

            cards.forEach(card => {
                const title = card.querySelector('.event-title').innerText.toLowerCase();
                const category = card.getAttribute('data-category');
                
                const matchesCategory = currentFilter === 'All' || category === currentFilter;
                const matchesSearch = title.includes(query);

                if (matchesCategory && matchesSearch) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        // --- Modals Logic ---
        function openDetailModal(title, category, date, location, summary) {
            document.getElementById('modal-title').innerText = title;
            document.getElementById('modal-category').innerText = category;
            document.getElementById('modal-meta').innerText = `${date} | ${location}`;
            document.getElementById('modal-desc').innerText = summary;
            
            // Re-bind action registration button inside detail modal
            document.getElementById('modal-action-btn').onclick = function() {
                closeDetailModal();
                openRegistrationModal(title);
            };

            document.getElementById('detail-modal').classList.remove('hidden');
        }

        function closeDetailModal() {
            document.getElementById('detail-modal').classList.add('hidden');
        }

        function openRegistrationModal(eventName) {
            document.getElementById('register-target-name').innerText = eventName;
            document.getElementById('register-event-field').value = eventName;
            document.getElementById('register-modal').classList.remove('hidden');
        }

        function closeRegistrationModal() {
            document.getElementById('register-modal').classList.add('hidden');
        }

        // Global Holder of active generated ticket details
        let activeGeneratedTicket = null;

        // SUBMIT REGISTRATION (AJAX post to backend to store in database)
        function submitRegistration(event) {
            event.preventDefault();

            const payload = {
                name: document.getElementById('reg-name').value,
                email: document.getElementById('reg-email').value,
                year: document.getElementById('reg-year').value,
                department: document.getElementById('reg-dept').value,
                college: document.getElementById('reg-college').value,
                eventName: document.getElementById('register-event-field').value
            };

            fetch('/api/events/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    activeGeneratedTicket = data.ticket;

                    // Populate success pass values
                    document.getElementById('pass-ticket-id').innerText = `ID: ${data.ticket.ticket_id}`;
                    document.getElementById('pass-name').innerText = data.ticket.name;
                    document.getElementById('pass-event-name').innerText = data.ticket.event_name;
                    document.getElementById('pass-dept').innerText = data.ticket.department;
                    document.getElementById('pass-year').innerText = data.ticket.year;

                    closeRegistrationModal();
                    document.getElementById('pass-modal').classList.remove('hidden');
                } else {
                    alert('Registration database insertion failed.');
                }
            })
            .catch(err => {
                console.error(err);
                alert('Connection failure to registration endpoints.');
            });
        }

        // GENERATE CLIENT-SIDE PDF PASS USING jsPDF CDN
        function generatePdfTicket() {
            if (!activeGeneratedTicket) return;

            const { jsPDF } = window.jspdf;
            const doc = new jsPDF({
                orientation: 'landscape',
                unit: 'px',
                format: [400, 240]
            });

            // 1. Dark cosmic background
            doc.setFillColor(13, 8, 28);
            doc.rect(0, 0, 400, 240, 'F');

            // 2. Neon cyan accent border
            doc.setDrawColor(6, 182, 212);
            doc.setLineWidth(2);
            doc.rect(10, 10, 380, 220);

            // 3. College Title
            doc.setTextColor(255, 255, 255);
            doc.setFont('Helvetica', 'bold');
            doc.setFontSize(14);
            doc.text('V.S.B. ENGINEERING COLLEGE', 30, 40);

            // 4. Department sub-header
            doc.setFontSize(8);
            doc.setTextColor(168, 85, 247);
            doc.text('DEPARTMENT OF ARTIFICIAL INTELLIGENCE & MACHINE LEARNING', 30, 52);

            // 5. Divider
            doc.setDrawColor(33, 20, 50);
            doc.line(30, 62, 370, 62);

            // 6. Pass/Ticket details
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(9);
            doc.text('STUDENT EMAIL:', 30, 80);
            doc.setFontSize(11);
            doc.text(activeGeneratedTicket.email, 30, 93);

            doc.setFontSize(9);
            doc.text('VISITOR NAME:', 30, 120);
            doc.setFontSize(11);
            doc.text(activeGeneratedTicket.name, 30, 133);

            doc.setFontSize(9);
            doc.text('YEAR / DEPARTMENT:', 30, 160);
            doc.setFontSize(11);
            doc.text(`${activeGeneratedTicket.year} - ${activeGeneratedTicket.department}`, 30, 173);

            // Event Title details
            doc.setFontSize(9);
            doc.text('REGISTERED EVENT TARGET:', 180, 80);
            doc.setFontSize(11);
            doc.setTextColor(6, 182, 212);
            doc.text(activeGeneratedTicket.event_name, 180, 93);

            doc.setFontSize(9);
            doc.setTextColor(255, 255, 255);
            doc.text('INSTITUTION OF ORIGIN:', 180, 120);
            doc.setFontSize(11);
            doc.text(activeGeneratedTicket.college, 180, 133);

            // Ticket unique ID and verification box
            doc.setTextColor(6, 182, 212);
            doc.setFontSize(12);
            doc.text(activeGeneratedTicket.ticket_id, 320, 40);

            doc.setDrawColor(255, 255, 255);
            doc.rect(310, 150, 60, 40);
            doc.setFontSize(6);
            doc.text('VSB SECURE ID', 315, 172);

            doc.save(`${activeGeneratedTicket.name}-VSB-Event-Pass.pdf`);
        }
    </script>
</body>
</html>