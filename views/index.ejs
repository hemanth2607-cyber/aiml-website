<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VSB Engineering College | Department of AI &amp; ML</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap');
        
        * {
            cursor: none !important;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #03000a;
            color: #f3f4f6;
            <% if (!user) { %>
            overflow: hidden !important; /* Lock visitor screen completely if not logged in */
            <% } else { %>
            overflow-x: hidden;
            <% } %>
        }

        .heading-font {
            font-family: 'Orbitron', sans-serif;
        }

        /* Starfield background */
        #starfield {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* Custom Cosmic Cursor Core */
        .custom-cursor {
            width: 12px;
            height: 12px;
            background: #06b6d4;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 10000;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 10px #06b6d4, 0 0 20px #2563eb;
            transition: transform 0.08s ease-out;
            will-change: transform;
        }

        /* Entrance Overlay Section (Holding the Cybernetic Brain & Gears Canvas) */
        #entrance-container {
            position: fixed;
            inset: 0;
            background-color: #060214; 
            z-index: 50;
            pointer-events: none;
            will-change: opacity, filter;
        }

        #neural-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 55;
            pointer-events: none;
        }

        /* Welcome Reveal Title Screen */
        #splash-screen {
            position: fixed;
            inset: 0;
            z-index: 45;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            pointer-events: none;
            transform-origin: center center;
            will-change: opacity, transform;
        }

        .neon-glow-cyan {
            text-shadow: 0 0 15px rgba(6, 182, 212, 0.7), 0 0 30px rgba(6, 182, 212, 0.3);
        }

        /* Interconnected Dashboard Portals (Nodes) */
        .portal-node {
            background: rgba(13, 8, 28, 0.85);
            border: 1px solid rgba(6, 182, 212, 0.25);
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.05);
            backdrop-filter: blur(12px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            will-change: transform, border-color, box-shadow;
        }

        .portal-node:hover {
            border-color: #a855f7;
            box-shadow: 0 0 30px rgba(168, 85, 247, 0.35);
            transform: scale(1.03) translateY(-4px);
        }

        #dashboard-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 10;
            pointer-events: none;
        }

        @media (max-width: 640px) {
            /* Disable custom cursor on mobile touch screens to prevent lag */
            .custom-cursor {
                display: none !important;
            }
            * {
                cursor: auto !important;
            }
        }
    </style>
</head>
<body class="bg-[#03000a]">

    <!-- Interactive Custom Cursor -->
    <div id="cursor-core" class="custom-cursor"></div>

    <!-- Cosmic Starfield Layer -->
    <canvas id="starfield"></canvas>

    <% if (!user) { %>
        <!-- ========================================================================
             1. PUBLIC VISITOR SCREEN (Locked: Brain, Gears, and Login link)
             ======================================================================== -->
        
        <!-- Opaque Neural/Gear transition overlay -->
        <div id="entrance-container">
            <canvas id="neural-canvas"></canvas>
        </div>

        <div id="splash-screen" class="px-4">
            <div class="text-center max-w-4xl mx-auto flex flex-col items-center justify-center">
                <!-- VSB Official Logo -->
                <div class="mb-4 sm:mb-6">
                    <img src="/images/vsb-logo.png" alt="V.S.B. College Logo" class="w-20 h-20 sm:w-28 sm:h-28 object-contain drop-shadow-[0_0_15px_rgba(255,255,255,0.15)]">
                </div>
                <span class="heading-font text-[10px] sm:text-xs tracking-[0.25em] sm:tracking-[0.4em] uppercase text-cyan-400 block mb-2 font-semibold">V.S.B. Engineering College</span>
                <h1 class="heading-font text-xl sm:text-3xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-wider leading-tight uppercase mb-8">
                    Artificial Intelligence <br>&amp; <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 neon-glow-cyan">Machine Learning</span>
                </h1>
                
                <!-- Main Locked Portal Sign-in Cable Terminal Button -->
                <a href="/login" class="pointer-events-auto heading-font text-xs sm:text-sm tracking-widest text-cyan-400 bg-cyan-950/20 hover:bg-cyan-500/20 border border-cyan-500/40 hover:border-cyan-400 px-8 py-3 rounded-full transition shadow-lg shadow-cyan-500/10 hover:shadow-cyan-400/20 relative z-[60]">
                    [ ACCESS PORTAL TERMINAL ]
                </a>
                
                <p class="text-[9px] text-gray-500 mt-6 tracking-widest font-mono uppercase">[ Login required to enter core indexes ]</p>
            </div>
        </div>
    <% } else { %>
        <!-- ========================================================================
             2. PRIVATE STUDENT DASHBOARD (Interconnected portals)
             ======================================================================== -->
        
        <!-- Global Navigation -->
        <nav class="fixed top-0 left-0 w-full z-40 bg-black/50 backdrop-blur-md border-b border-white/5 px-4 sm:px-6 py-3 sm:py-4 flex flex-col sm:flex-row justify-between items-center gap-3 sm:gap-0">
            <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
                <div class="flex items-center space-x-2 sm:space-x-3">
                    <img src="/images/vsb-logo.png" alt="V.S.B. Logo" class="w-6 h-6 sm:w-8 sm:h-8 object-contain">
                    <a href="/" class="heading-font text-xs sm:text-sm font-bold tracking-widest text-white">
                        V.S.B. AI &amp; ML
                    </a>
                </div>
                <div class="text-[8px] sm:text-[10px] text-gray-400 mt-1 font-normal tracking-wide leading-none max-w-[240px] sm:max-w-md" style="font-family: 'Times New Roman', Times, serif;">
                    Affiliated to Anna University, Chennai &amp; Approved by AICTE, New Delhi
                </div>
            </div>
            
            <div class="flex items-center space-x-6 text-xs font-mono">
                <span class="text-purple-300 font-semibold"><%= user.email.split('@')[0] %> (Student)</span>
                <a href="/logout" class="bg-red-950/40 border border-red-500/30 hover:bg-red-900/50 text-red-300 px-3 py-1 rounded transition">Logoff</a>
            </div>
        </nav>

        <!-- Interconnected portal dashboard -->
        <div class="relative w-screen min-h-screen flex items-center justify-center pt-24 pb-12 overflow-hidden">
            <!-- Neural Wiring Canvas Layer -->
            <canvas id="dashboard-canvas"></canvas>

            <div class="relative z-30 max-w-5xl mx-auto px-6 w-full">
                <div class="text-center mb-16">
                    <span class="text-xs uppercase font-mono tracking-widest text-cyan-400">[ SECURED INDEX CORE ]</span>
                    <h1 class="heading-font text-3xl sm:text-5xl font-extrabold text-white mt-2 uppercase">VSB AI &amp; ML Portal</h1>
                    <p class="text-gray-400 text-xs sm:text-sm mt-3 max-w-lg mx-auto">Select a terminal node below to explore active sub-systems.</p>
                </div>

                <!-- Triangular Interconnected Portal Nodes Grid -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
                    
                    <!-- Node 1: Events -->
                    <a id="node-events" href="/events" class="portal-node p-8 rounded-3xl flex flex-col justify-between h-64 hover:scale-[1.03]">
                        <div>
                            <span class="text-[9px] font-mono tracking-widest text-cyan-400 block mb-2">[ SYSTEM 01 ]</span>
                            <h2 class="heading-font text-lg sm:text-xl font-bold text-white mb-3">EVENTS PORTAL</h2>
                            <p class="text-gray-400 text-xs leading-relaxed">Access active engineering symposiums, technical challenges, and live department hackathons.</p>
                        </div>
                        <span class="text-xs text-cyan-400 font-mono tracking-widest">[ ACCESS TERMINAL → ]</span>
                    </a>

                    <!-- Node 2: Academics -->
                    <a id="node-academics" href="/academics" class="portal-node p-8 rounded-3xl flex flex-col justify-between h-64 hover:scale-[1.03]">
                        <div>
                            <span class="text-[9px] font-mono tracking-widest text-purple-400 block mb-2">[ SYSTEM 02 ]</span>
                            <h2 class="heading-font text-lg sm:text-xl font-bold text-white mb-3">ACADEMIC UPDATES</h2>
                            <p class="text-gray-400 text-xs leading-relaxed">Review syllabus configurations, research paper submissions, and high-performance laboratory structures.</p>
                        </div>
                        <span class="text-xs text-purple-400 font-mono tracking-widest">[ ACCESS TERMINAL → ]</span>
                    </a>

                    <!-- Node 3: Announcements -->
                    <a id="node-announcements" href="/announcements" class="portal-node p-8 rounded-3xl flex flex-col justify-between h-64 hover:scale-[1.03]">
                        <div>
                            <span class="text-[9px] font-mono tracking-widest text-pink-400 block mb-2">[ SYSTEM 03 ]</span>
                            <h2 class="heading-font text-lg sm:text-xl font-bold text-white mb-3">ANNOUNCEMENTS</h2>
                            <p class="text-gray-400 text-xs leading-relaxed">Acquire official semester notifications, academic calendars, and real-time department alerts.</p>
                        </div>
                        <span class="text-xs text-pink-400 font-mono tracking-widest">[ ACCESS TERMINAL → ]</span>
                    </a>

                </div>
            </div>
        </div>

        <!-- Global Footer -->
        <footer class="border-t border-white/5 py-8 relative z-30 bg-black/60 text-center px-4">
            <p class="text-[10px] text-gray-500 font-normal">V.S.B. Engineering College, Karur, Tamil Nadu, India.</p>
            <p class="text-[9px] text-gray-600 mt-1">&copy; 2025 VSB Department of AI &amp; ML. All Rights Reserved.</p>
        </footer>
    <% } %>

    <!-- Scripting for Cursors, Stars, and Bidirectional Scroll Animations -->
    <script>
        // Custom Cursor Coordinate tracking
        const cursorCore = document.getElementById('cursor-core');
        let mouseX = 0;
        let mouseY = 0;

        document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            
            cursorCore.style.left = `${mouseX}px`;
            cursorCore.style.top = `${mouseY}px`;

            // Spawn Stardust particles on mouse move (only on desktop screens)
            if (window.innerWidth > 640 && Math.random() > 0.3) {
                spawnStardustParticle(mouseX, mouseY);
            }
        });

        // Hover enlargements
        document.querySelectorAll('a, button, .galaxy-card, .portal-node').forEach(element => {
            element.addEventListener('mouseenter', () => {
                cursorCore.style.transform = 'translate(-50%, -50%) scale(1.6)';
                cursorCore.style.backgroundColor = '#06b6d4';
            });
            element.addEventListener('mouseleave', () => {
                cursorCore.style.transform = 'translate(-50%, -50%) scale(1)';
                cursorCore.style.backgroundColor = '#06b6d4';
            });
        });

        // Canvas Stars & Stardust Particle Engine
        const canvas = document.getElementById('starfield');
        const ctx = canvas.getContext('2d');
        let stars = [];
        let stardustParticles = []; // Trailing stardust array

        function resizeStars() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            initializeStarsArray();
        }

        function initializeStarsArray() {
            stars = [];
            const count = Math.floor((canvas.width * canvas.height) / 7500);
            for (let i = 0; i < count; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    radius: Math.random() * 1.5,
                    brightness: Math.random(),
                    speed: 0.05 + Math.random() * 0.08
                });
            }
        }

        // Spawn a trailing particle
        function spawnStardustParticle(x, y) {
            stardustParticles.push({
                x: x,
                y: y,
                vx: (Math.random() - 0.5) * 1.5, 
                vy: (Math.random() - 0.5) * 1.5 + 0.5, 
                radius: 1 + Math.random() * 2,
                opacity: 1,
                decay: 0.015 + Math.random() * 0.015,
                color: Math.random() > 0.5 ? '168, 85, 247' : '6, 182, 212' // Purple or Cyan
            });
        }

        function drawStarsFrame() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#03000a';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Draw background stars
            stars.forEach(star => {
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 255, 255, ${star.brightness})`;
                ctx.fill();

                star.brightness += star.speed * (Math.random() - 0.5);
                if (star.brightness < 0.1) star.brightness = 0.1;
                if (star.brightness > 1) star.brightness = 1;
            });

            // Draw and update trailing cursor stardust
            for (let i = stardustParticles.length - 1; i >= 0; i--) {
                const p = stardustParticles[i];
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                
                const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius * 2);
                gradient.addColorStop(0, `rgba(${p.color}, ${p.opacity})`);
                gradient.addColorStop(1, `rgba(${p.color}, 0)`);
                
                ctx.fillStyle = gradient;
                ctx.fill();

                p.x += p.vx;
                p.y += p.vy;
                p.opacity -= p.decay;

                if (p.opacity <= 0) {
                    stardustParticles.splice(i, 1);
                }
            }

            requestAnimationFrame(drawStarsFrame);
        }

        window.addEventListener('resize', resizeStars);
        resizeStars();
        drawStarsFrame();


        /* 
           ========================================================================
           LOCKED PUBLIC ENTRANCE GATEWAY (BRAIN, SPINNING GEARS & AXON TERMINALS)
           ========================================================================
        */
        <% if (!user) { %>
            const nCanvas = document.getElementById('neural-canvas');
            const nCtx = nCanvas.getContext('2d');
            let brainX = 0, brainY = 0, brainSize = 100;
            let gears = [];
            let axonPathways = [];

            function resizeNeuralCanvas() {
                nCanvas.width = window.innerWidth;
                nCanvas.height = window.innerHeight;
                initializeNeuralVisuals();
            }

            // Draw mechanical gears
            function drawGear(ctx, x, y, radius, teeth, angle, color) {
                ctx.beginPath();
                const innerRadius = radius * 0.75;
                const outerRadius = radius * 1.15;
                
                for (let i = 0; i < teeth; i++) {
                    const step = (Math.PI * 2) / teeth;
                    const theta = i * step + angle;
                    
                    ctx.lineTo(x + Math.cos(theta) * innerRadius, y + Math.sin(theta) * innerRadius);
                    ctx.lineTo(x + Math.cos(theta + step * 0.3) * outerRadius, y + Math.sin(theta + step * 0.3) * outerRadius);
                    ctx.lineTo(x + Math.cos(theta + step * 0.7) * outerRadius, y + Math.sin(theta + step * 0.7) * outerRadius);
                    ctx.lineTo(x + Math.cos(theta + step) * innerRadius, y + Math.sin(theta + step) * innerRadius);
                }
                
                ctx.closePath();
                ctx.fillStyle = `rgba(${color}, 0.1)`;
                ctx.fill();
                ctx.strokeStyle = `rgba(${color}, 0.5)`;
                ctx.lineWidth = 1.5;
                ctx.stroke();
                
                // Draw central shaft hole
                ctx.beginPath();
                ctx.arc(x, y, radius * 0.25, 0, Math.PI * 2);
                ctx.fillStyle = '#060214';
                ctx.fill();
                ctx.stroke();
            }

            // Draw stylized biological brain
            function drawBrain(ctx, x, y, size) {
                // Left Lobe
                ctx.beginPath();
                ctx.ellipse(x - size * 0.35, y, size * 0.5, size * 0.65, 0, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(6, 182, 212, 0.05)';
                ctx.fill();
                ctx.strokeStyle = 'rgba(6, 182, 212, 0.3)';
                ctx.lineWidth = 2.5;
                ctx.stroke();

                // Right Lobe
                ctx.beginPath();
                ctx.ellipse(x + size * 0.35, y, size * 0.5, size * 0.65, 0, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(168, 85, 247, 0.05)';
                ctx.fill();
                ctx.strokeStyle = 'rgba(168, 85, 247, 0.3)';
                ctx.lineWidth = 2.5;
                ctx.stroke();

                // Brain internal sulci (wrinkles)
                ctx.beginPath();
                ctx.moveTo(x - size * 0.3, y - size * 0.3);
                ctx.bezierCurveTo(x - size * 0.5, y - size * 0.1, x - size * 0.1, y + size * 0.2, x - size * 0.2, y + size * 0.4);
                ctx.moveTo(x + size * 0.3, y - size * 0.3);
                ctx.bezierCurveTo(x + size * 0.5, y - size * 0.1, x + size * 0.1, y + size * 0.2, x + size * 0.2, y + size * 0.4);
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.15)';
                ctx.lineWidth = 1.5;
                ctx.stroke();
            }

            function initializeNeuralVisuals() {
                const w = nCanvas.width;
                const h = nCanvas.height;

                brainX = w * 0.5;
                brainY = h * 0.5;
                brainSize = w < 640 ? 65 : 110;

                // Setup 4 spinning gears around the central brain
                gears = [
                    { x: w * 0.25, y: h * 0.35, r: w < 640 ? 30 : 50, teeth: 10, speed: 0.015, angle: 0, color: '6, 182, 212' },
                    { x: w * 0.75, y: h * 0.35, r: w < 640 ? 35 : 55, teeth: 12, speed: -0.012, angle: 0, color: '168, 85, 247' },
                    { x: w * 0.20, y: h * 0.65, r: w < 640 ? 40 : 60, teeth: 14, speed: -0.01, angle: 0, color: '168, 85, 247' },
                    { x: w * 0.70, y: h * 0.70, r: w < 640 ? 30 : 45, teeth: 8, speed: 0.02, angle: 0, color: '6, 182, 212' }
                ];

                axonPathways = [];
                // Connect gears to the brain with nerve-wires
                gears.forEach(g => {
                    axonPathways.push({ x1: brainX, y1: brainY, x2: g.x, y2: g.y, color: g.color, pulses: [] });
                });
            }

            window.addEventListener('resize', resizeNeuralCanvas);
            resizeStars(); // Run alongside starfield
            resizeNeuralCanvas();

            function drawEntranceLoop() {
                nCtx.clearRect(0, 0, nCanvas.width, nCanvas.height);

                // 1. Draw central brain
                drawBrain(nCtx, brainX, brainY, brainSize);

                // 2. Draw nerve pathways and moving electrical charges
                axonPathways.forEach(path => {
                    nCtx.beginPath();
                    nCtx.moveTo(path.x1, path.y1);
                    nCtx.lineTo(path.x2, path.y2);
                    nCtx.strokeStyle = `rgba(${path.color}, 0.15)`;
                    nCtx.lineWidth = 1.5;
                    nCtx.stroke();

                    // Periodically spawn electrical pulses down the axons
                    if (Math.random() > 0.98) {
                        path.pulses.push({ progress: 0, speed: 0.01 + Math.random() * 0.015 });
                    }

                    // Render active electrical pulses
                    for (let i = path.pulses.length - 1; i >= 0; i--) {
                        const p = path.pulses[i];
                        p.progress += p.speed;

                        const px = path.x1 + (path.x2 - path.x1) * p.progress;
                        const py = path.y1 + (path.y2 - path.y1) * p.progress;

                        nCtx.beginPath();
                        nCtx.arc(px, py, 3.5, 0, Math.PI * 2);
                        nCtx.fillStyle = '#ffffff';
                        nCtx.shadowColor = `rgb(${path.color})`;
                        nCtx.shadowBlur = 8;
                        nCtx.fill();
                        nCtx.shadowBlur = 0; // reset

                        if (p.progress >= 1) {
                            path.pulses.splice(i, 1);
                        }
                    }
                });

                // 3. Draw and rotate gears
                gears.forEach(g => {
                    g.angle += g.speed;
                    drawGear(nCtx, g.x, g.y, g.r, g.teeth, g.angle, g.color);
                });

                requestAnimationFrame(drawEntranceLoop);
            }
            requestAnimationFrame(drawEntranceLoop);
        <% } %>

        /* 
           ========================================================================
           PRIVATE CONNECTED NEURAL PORTALS ENGINE (POST-LOGIN DASHBOARD)
           ========================================================================
        */
        <% if (user) { %>
            const dCanvas = document.getElementById('dashboard-canvas');
            const dCtx = dCanvas.getContext('2d');
            let connections = [];

            function resizeDashboardCanvas() {
                dCanvas.width = window.innerWidth;
                dCanvas.height = window.innerHeight;
                initializePortalConnections();
            }

            function initializePortalConnections() {
                connections = [];
                const elEvents = document.getElementById('node-events');
                const elAcademics = document.getElementById('node-academics');
                const elAnnouncements = document.getElementById('node-announcements');

                if (!elEvents || !elAcademics || !elAnnouncements) return;

                // Grab center coords of each portal card node
                const getCenter = (el) => {
                    const r = el.getBoundingClientRect();
                    return {
                        x: r.left + r.width / 2 + window.scrollX,
                        y: r.top + r.height / 2 + window.scrollY
                    };
                };

                const pts = [
                    { name: 'events', pt: getCenter(elEvents), color: '6, 182, 212' },
                    { name: 'academics', pt: getCenter(elAcademics), color: '168, 85, 247' },
                    { name: 'announcements', pt: getCenter(elAnnouncements), color: '244, 63, 94' }
                ];

                // Form triangular synapses
                connections.push({ from: pts[0], to: pts[1], pulses: [] });
                connections.push({ from: pts[1], to: pts[2], pulses: [] });
                connections.push({ from: pts[2], to: pts[0], pulses: [] });
            }

            window.addEventListener('resize', resizeDashboardCanvas);
            resizeStars(); // Run alongside background stars
            setTimeout(resizeDashboardCanvas, 300); // Slight delay to ensure DOM coordinates settle

            function drawDashboardConnections() {
                dCtx.clearRect(0, 0, dCanvas.width, dCanvas.height);

                connections.forEach(conn => {
                    dCtx.beginPath();
                    dCtx.moveTo(conn.from.pt.x, conn.from.pt.y);
                    dCtx.lineTo(conn.to.pt.x, conn.to.pt.y);
                    dCtx.strokeStyle = 'rgba(255, 255, 255, 0.06)';
                    dCtx.lineWidth = 2.0;
                    dCtx.stroke();

                    // Spawn nerve-pulses
                    if (Math.random() > 0.98) {
                        conn.pulses.push({ progress: 0, speed: 0.008 + Math.random() * 0.01 });
                    }

                    // Render pulses
                    for (let i = conn.pulses.length - 1; i >= 0; i--) {
                        const p = conn.pulses[i];
                        p.progress += p.speed;

                        const px = conn.from.pt.x + (conn.to.pt.x - conn.from.pt.x) * p.progress;
                        const py = conn.from.pt.y + (conn.to.pt.y - conn.from.pt.y) * p.progress;

                        dCtx.beginPath();
                        dCtx.arc(px, py, 4.0, 0, Math.PI * 2);
                        
                        // Active node matching color
                        dCtx.fillStyle = `rgb(${conn.from.color})`;
                        dCtx.shadowColor = `rgb(${conn.from.color})`;
                        dCtx.shadowBlur = 10;
                        dCtx.fill();
                        dCtx.shadowBlur = 0; // reset

                        if (p.progress >= 1) {
                            conn.pulses.splice(i, 1);
                        }
                    }
                });

                requestAnimationFrame(drawDashboardConnections);
            }
            requestAnimationFrame(drawDashboardConnections);
        <% } %>
    </script>
</body>
</html>