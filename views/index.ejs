<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>V.S.B. Engineering College | Department of AI &amp; ML</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap');
        
        * {
            cursor: none !important;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #03000a;
            color: #f3f4f6;
            overflow-x: hidden;
        }

        .heading-font {
            font-family: 'Orbitron', sans-serif;
        }

        /* Starfield background */
        #starfield {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* Custom Cosmic Cursor Core */
        .custom-cursor {
            width: 12px;
            height: 12px;
            background: #06b6d4;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 10000;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 10px #06b6d4, 0 0 20px #2563eb;
            transition: transform 0.08s ease-out;
            will-change: transform;
        }

        /* Entrance Overlay Section (Holding the Neural Network Canvas) */
        #entrance-container {
            position: fixed;
            inset: 0;
            background-color: #060214; /* Deep cybernetic dark violet background */
            z-index: 50;
            pointer-events: none;
            will-change: opacity, filter;
        }

        #neural-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 55;
            pointer-events: none;
        }

        /* Welcome Reveal Title Screen */
        #splash-screen {
            position: fixed;
            inset: 0;
            z-index: 45;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            pointer-events: none;
            transform-origin: center center;
            will-change: opacity, transform;
        }

        .neon-glow-cyan {
            text-shadow: 0 0 15px rgba(6, 182, 212, 0.7), 0 0 30px rgba(6, 182, 212, 0.3);
        }

        .galaxy-card {
            background: rgba(13, 8, 28, 0.8);
            border: 1px solid rgba(139, 92, 246, 0.2);
            backdrop-filter: blur(12px);
            transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        }

        .galaxy-card:hover {
            transform: translateY(-4px);
            border-color: rgba(6, 182, 212, 0.4);
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.15);
        }

        @media (max-width: 640px) {
            /* Disable custom cursor and stardust trail on mobile touch devices */
            .custom-cursor {
                display: none !important;
            }
            * {
                cursor: auto !important;
            }
        }
    </style>
</head>
<body class="bg-[#03000a]">

    <!-- Interactive Custom Cursor -->
    <div id="cursor-core" class="custom-cursor"></div>

    <!-- Cosmic Starfield & Stardust Particle Layer -->
    <canvas id="starfield"></canvas>

    <!-- Opaque Neural Network Transition Overlay -->
    <div id="entrance-container">
        <canvas id="neural-canvas"></canvas>
    </div>

    <!-- Entrance Title Card -->
    <div id="splash-screen" class="px-4">
        <div class="text-center max-w-4xl mx-auto">
            <!-- VSB Official Logo -->
            <div class="mb-4 sm:mb-6 flex justify-center">
                <img src="/images/vsb-logo.png" alt="V.S.B. College Logo" class="w-20 h-20 sm:w-28 sm:h-28 md:w-32 md:h-32 object-contain drop-shadow-[0_0_15px_rgba(255,255,255,0.15)]">
            </div>
            <span class="heading-font text-[10px] sm:text-xs tracking-[0.25em] sm:tracking-[0.4em] uppercase text-cyan-400 block mb-2 font-semibold">V.S.B. Engineering College</span>
            <h1 class="heading-font text-xl sm:text-3xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-wider leading-tight uppercase">
                Artificial Intelligence <br>&amp; <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 neon-glow-cyan">Machine Learning</span>
            </h1>
            
            <!-- Dynamic Scroll Prompt -->
            <div class="mt-12 sm:mt-16 flex flex-col items-center justify-center space-y-2">
                <span class="text-cyan-400 text-[9px] sm:text-[10px] tracking-[0.3em] font-mono animate-pulse">[ SCROLL TO REVEAL ]</span>
                <div class="text-cyan-400 text-xs animate-bounce font-mono">↓</div>
            </div>
        </div>
    </div>

    <!-- Global Navigation -->
    <nav class="fixed top-0 left-0 w-full z-40 bg-black/50 backdrop-blur-md border-b border-white/5 px-4 sm:px-6 py-3 sm:py-4 flex flex-col sm:flex-row justify-between items-center gap-3 sm:gap-0">
        <!-- Brand Header with Logo and Accreditation Details Sub-label -->
        <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <img src="/images/vsb-logo.png" alt="V.S.B. Logo" class="w-6 h-6 sm:w-8 sm:h-8 object-contain">
                <a href="/" class="heading-font text-xs sm:text-sm font-bold tracking-widest text-white">
                    V.S.B. AI &amp; ML
                </a>
            </div>
            <!-- Accreditation Details (Wrapped dynamically on mobile) -->
            <div class="text-[8px] sm:text-[10px] text-gray-400 mt-1 font-normal tracking-wide leading-none max-w-[240px] sm:max-w-md" style="font-family: 'Times New Roman', Times, serif;">
                Affiliated to Anna University, Chennai &amp; Approved by AICTE, New Delhi
            </div>
        </div>
        
        <!-- Navigation Menu -->
        <div class="flex items-center space-x-4 sm:space-x-6 text-[10px] sm:text-xs font-mono">
            <a href="#feed" class="text-gray-300 hover:text-cyan-400 transition">Feeds</a>
            <a href="#blogs" class="text-gray-300 hover:text-purple-400 transition">Syllabus &amp; Logs</a>
            <% if (user) { %>
                <% if (user.role === 'admin') { %>
                    <a href="/admin" class="text-yellow-400 hover:text-yellow-300 transition">Admin Console</a>
                <% } %>
                <span class="text-purple-300 font-semibold"><%= user.email.split('@')[0] %></span>
                <a href="/logout" class="bg-red-950/40 border border-red-500/30 hover:bg-red-900/50 text-red-300 px-2 py-0.5 sm:px-3 sm:py-1 rounded transition">Exit</a>
            <% } else { %>
                <a href="/login" class="bg-purple-900/40 border border-purple-500/30 hover:bg-purple-800/60 text-purple-200 px-2.5 py-1 sm:px-3 sm:py-1.5 rounded transition">Portal Sign-in</a>
            <% } %>
        </div>
    </nav>

    <!-- Main Dynamic Interface Layout -->
    <main id="main-content" class="relative z-30 max-w-6xl mx-auto px-4 sm:px-6 pb-24" style="opacity: 0; transform: translateY(40px); will-change: opacity, transform;">
        
        <!-- VSB College Introductory Banner -->
        <header class="mb-16 sm:mb-24 text-center">
            <div class="flex justify-center mb-4">
                <img src="/images/vsb-logo.png" alt="V.S.B. Logo" class="w-12 h-12 sm:w-16 sm:h-16 object-contain">
            </div>
            <span class="text-xs uppercase font-mono tracking-widest text-purple-400">Department of AI &amp; ML</span>
            <h2 class="heading-font text-2xl sm:text-3xl md:text-4xl font-black text-white mt-2 px-2">
                V.S.B. Engineering College
            </h2>
            <p class="text-gray-400 text-xs sm:text-sm md:text-base max-w-xl mx-auto mt-4 leading-relaxed px-4">
                Empowering the future through state-of-the-art computational algorithms, deep learning models, and complex data analytic infrastructures.
            </p>
        </header>

        <!-- Department Overview Static Grid -->
        <section id="feed" class="mb-16 sm:mb-24 scroll-mt-24">
            <div class="flex items-center space-x-3 mb-6 sm:mb-8">
                <span class="h-1.5 w-1.5 rounded-full bg-cyan-400 animate-ping"></span>
                <h3 class="heading-font text-lg sm:text-xl font-bold tracking-wider">Department Features</h3>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="galaxy-card p-6 rounded-2xl">
                    <div class="text-[10px] text-purple-400 font-mono tracking-widest mb-2">[ INFRASTRUCTURE ]</div>
                    <h4 class="heading-font text-base sm:text-lg font-bold mb-2 text-white">Modern GPU Lab</h4>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Dedicated computing workstations equipped with deep learning software stacks for training neural networks.
                    </p>
                </div>
                <div class="galaxy-card p-6 rounded-2xl">
                    <div class="text-[10px] text-cyan-400 font-mono tracking-widest mb-2">[ CURRICULUM ]</div>
                    <h4 class="heading-font text-base sm:text-lg font-bold mb-2 text-white">Industry Alignment</h4>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Course structures oriented around continuous real-world integration, natural language processing, and robotics.
                    </p>
                </div>
                <div class="galaxy-card p-6 rounded-2xl">
                    <div class="text-[10px] text-pink-400 font-mono tracking-widest mb-2">[ COLLABORATION ]</div>
                    <h4 class="heading-font text-base sm:text-lg font-bold mb-2 text-white">Global Research</h4>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Working in partnership with leading tech clusters to support student project internships and secure placements.
                    </p>
                </div>
            </div>
        </section>

        <!-- Dynamic Blogs Section from Database -->
        <section id="blogs" class="scroll-mt-24">
            <div class="flex items-center space-x-3 mb-6 sm:mb-8">
                <span class="h-1.5 w-1.5 rounded-full bg-purple-400 animate-pulse"></span>
                <h3 class="heading-font text-lg sm:text-xl font-bold tracking-wider">Academic Publications &amp; News</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">
                <% if (blogs && blogs.length > 0) { %>
                    <% blogs.forEach(blog => { %>
                        <article class="galaxy-card p-6 sm:p-8 rounded-2xl flex flex-col justify-between">
                            <div>
                                <div class="flex justify-between items-center text-[10px] text-gray-500 mb-4 font-mono">
                                    <span class="border border-purple-500/20 text-purple-300 bg-purple-950/20 px-2 py-0.5 rounded-full"><%= blog.category %></span>
                                    <span><%= blog.date %></span>
                                </div>
                                <h4 class="heading-font text-lg sm:text-xl font-bold text-white mb-2"><%= blog.title %></h4>
                                <p class="text-gray-400 text-xs leading-relaxed mb-6"><%= blog.summary %></p>
                            </div>
                            <div class="flex justify-between items-center pt-4 border-t border-white/5 text-[10px] sm:text-xs text-gray-500 font-mono">
                                <span>Registry: Official VSB Source</span>
                                <span class="text-cyan-400 font-semibold cursor-pointer">Explore →</span>
                            </div>
                        </article>
                    <% }) %>
                <% } else { %>
                    <p class="text-gray-500 text-xs col-span-2">No educational logs reported yet.</p>
                <% } %>
            </div>
        </section>
    </main>

    <!-- Global Footer -->
    <footer class="border-t border-white/5 py-8 sm:py-12 relative z-30 bg-black/60 backdrop-blur-md mt-24 text-center px-4">
        <p class="text-[10px] sm:text-xs text-gray-400 font-normal">V.S.B. Engineering College, Karur, Tamil Nadu, India.</p>
        <p class="text-[9px] sm:text-xs text-gray-600 mt-2">&copy; 2025 VSB Department of Artificial Intelligence and Machine Learning. All Rights Reserved.</p>
    </footer>

    <!-- Scripting for Cursors, Stars, and Bidirectional Scroll Animations -->
    <script>
        // Custom Cursor Coordinate tracking
        const cursorCore = document.getElementById('cursor-core');
        let mouseX = 0;
        let mouseY = 0;

        document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            
            cursorCore.style.left = `${mouseX}px`;
            cursorCore.style.top = `${mouseY}px`;

            // Spawn Stardust particles on mouse move (only on desktop screens)
            if (window.innerWidth > 640 && Math.random() > 0.3) {
                spawnStardustParticle(mouseX, mouseY);
            }
        });

        // Hover enlargements
        document.querySelectorAll('a, button, .galaxy-card').forEach(element => {
            element.addEventListener('mouseenter', () => {
                cursorCore.style.transform = 'translate(-50%, -50%) scale(1.6)';
                cursorCore.style.backgroundColor = '#06b6d4';
            });
            element.addEventListener('mouseleave', () => {
                cursorCore.style.transform = 'translate(-50%, -50%) scale(1)';
                cursorCore.style.backgroundColor = '#06b6d4';
            });
        });

        // Canvas Stars & Stardust Particle Engine
        const canvas = document.getElementById('starfield');
        const ctx = canvas.getContext('2d');
        let stars = [];
        let stardustParticles = []; // Trailing stardust array

        function resizeStars() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            initializeStarsArray();
        }

        function initializeStarsArray() {
            stars = [];
            const count = Math.floor((canvas.width * canvas.height) / 7500);
            for (let i = 0; i < count; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    radius: Math.random() * 1.5,
                    brightness: Math.random(),
                    speed: 0.05 + Math.random() * 0.08
                });
            }
        }

        // Spawn a trailing particle
        function spawnStardustParticle(x, y) {
            stardustParticles.push({
                x: x,
                y: y,
                vx: (Math.random() - 0.5) * 1.5, // Drift sideways
                vy: (Math.random() - 0.5) * 1.5 + 0.5, // Slight downward sink
                radius: 1 + Math.random() * 2,
                opacity: 1,
                decay: 0.015 + Math.random() * 0.015,
                color: Math.random() > 0.5 ? '168, 85, 247' : '6, 182, 212' // Purple or Cyan
            });
        }

        function drawStarsFrame() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#03000a';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // 1. Draw background stars
            stars.forEach(star => {
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 255, 255, ${star.brightness})`;
                ctx.fill();

                star.brightness += star.speed * (Math.random() - 0.5);
                if (star.brightness < 0.1) star.brightness = 0.1;
                if (star.brightness > 1) star.brightness = 1;
            });

            // 2. Draw and update trailing cursor stardust
            for (let i = stardustParticles.length - 1; i >= 0; i--) {
                const p = stardustParticles[i];
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                
                // Glowing radial gradient for stardust look
                const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius * 2);
                gradient.addColorStop(0, `rgba(${p.color}, ${p.opacity})`);
                gradient.addColorStop(1, `rgba(${p.color}, 0)`);
                
                ctx.fillStyle = gradient;
                ctx.fill();

                // Apply kinematics
                p.x += p.vx;
                p.y += p.vy;
                p.opacity -= p.decay;

                // Remove dead particles
                if (p.opacity <= 0) {
                    stardustParticles.splice(i, 1);
                }
            }

            requestAnimationFrame(drawStarsFrame);
        }

        window.addEventListener('resize', resizeStars);
        resizeStars();
        drawStarsFrame();


        /* 
           ========================================================================
           SCROLL REVEAL CONFIGURATION TIMELINES
           ========================================================================
        */
        const TOTAL_PAGE_MULTIPLIER = 4.0; // Total scroll range of the page
        const LERP_EASE = 0.06;            // Deceleration physics factor for scroll easing.

        const entranceContainer = document.getElementById('entrance-container');
        const splashScreen = document.getElementById('splash-screen');
        const mainContent = document.getElementById('main-content');

        let targetScrollY = 0;
        let interpolatedScrollY = 0;

        // Space out content height
        function adjustMainContentMargin() {
            const spacerHeight = window.innerHeight * TOTAL_PAGE_MULTIPLIER;
            mainContent.style.marginTop = `${spacerHeight}px`;
        }

        window.addEventListener('resize', adjustMainContentMargin);
        adjustMainContentMargin();

        window.addEventListener('scroll', () => {
            targetScrollY = window.scrollY;
        });


        /* 
           ========================================================================
           NEURAL NETWORK DISSOCIATION ENGINE (CANVAS)
           ========================================================================
        */
        const nCanvas = document.getElementById('neural-canvas');
        const nCtx = nCanvas.getContext('2d');
        let neuralNodes = [];
        let neuralLines = [];

        function resizeNeuralCanvas() {
            nCanvas.width = window.innerWidth;
            nCanvas.height = window.innerHeight;
            initializeNeuralNetwork();
        }

        function initializeNeuralNetwork() {
            neuralNodes = [];
            neuralLines = [];

            const w = nCanvas.width;
            const h = nCanvas.height;

            // Structure a 4-layer feedforward neural network (3-4-4-2)
            const layers = [3, 4, 4, 2];
            const nodeRadius = window.innerWidth < 640 ? 5 : 8;

            // Generate Nodes in Layer Structures (relative coordinates)
            layers.forEach((nodeCount, layerIdx) => {
                const xPos = w * (0.2 + (layerIdx * 0.2)); // Space layers horizontally (20%, 40%, 60%, 80%)
                
                for (let i = 0; i < nodeCount; i++) {
                    const yPos = h * (0.2 + (i * (0.6 / (nodeCount - 1 || 1)))); // Space nodes vertically
                    
                    neuralNodes.push({
                        layer: layerIdx,
                        idx: i,
                        startX: xPos,
                        startY: yPos,
                        currentX: xPos,
                        currentY: yPos,
                        radius: nodeRadius,
                        // Scatter directions when breaking down (random vectors)
                        driftX: (Math.random() - 0.5) * w * 1.5,
                        driftY: (Math.random() - 0.5) * h * 1.5,
                        glowColor: layerIdx % 2 === 0 ? '6, 182, 212' : '168, 85, 247' // Cyan/Purple alternating layers
                    });
                }
            });

            // Map Connections (axon pathways) between adjacent layers
            for (let i = 0; i < neuralNodes.length; i++) {
                const nodeA = neuralNodes[i];
                for (let j = i + 1; j < neuralNodes.length; j++) {
                    const nodeB = neuralNodes[j];
                    if (nodeB.layer === nodeA.layer + 1) {
                        neuralLines.push({ from: nodeA, to: nodeB });
                    }
                }
            }
        }

        window.addEventListener('resize', resizeNeuralCanvas);
        resizeNeuralCanvas();

        // Frame update rendering loop
        function updateParallaxFrames() {
            interpolatedScrollY += (targetScrollY - interpolatedScrollY) * LERP_EASE;

            const viewportHeight = window.innerHeight;

            /* 1. NEURAL DISSOCIATION TIMELINE (Dissolves completely at exactly 1 viewport scroll) */
            const breakDistance = viewportHeight * 1.1; 
            const breakProgress = Math.min(Math.max(interpolatedScrollY / breakDistance, 0), 1);
            
            // Render Neural Network state
            nCtx.clearRect(0, 0, nCanvas.width, nCanvas.height);
            
            // Calculate and Draw Lines (Axons)
            const lineOpacity = Math.max(1 - breakProgress * 2.0, 0); // Lines snap/fade early
            neuralLines.forEach(line => {
                nCtx.beginPath();
                nCtx.moveTo(line.from.currentX, line.from.startY + (line.from.driftY * breakProgress));
                nCtx.lineTo(line.to.currentX, line.to.startY + (line.to.driftY * breakProgress));
                nCtx.strokeStyle = `rgba(139, 92, 246, ${lineOpacity * 0.15})`;
                nCtx.lineWidth = 1;
                nCtx.stroke();
            });

            // Calculate, Draw and Move Nodes (Synapses)
            neuralNodes.forEach(node => {
                // Nodes drift further apart as progress ratio increases
                node.currentX = node.startX + (node.driftX * breakProgress);
                node.currentY = node.startY + (node.driftY * breakProgress);

                nCtx.beginPath();
                nCtx.arc(node.currentX, node.currentY, node.radius, 0, Math.PI * 2);
                
                // Inner solid core
                nCtx.fillStyle = `rgba(255, 255, 255, ${1 - breakProgress})`;
                nCtx.fill();

                // Outer glowing aura
                const nodeGlow = nCtx.createRadialGradient(node.currentX, node.currentY, 0, node.currentX, node.currentY, node.radius * 2.5);
                nodeGlow.addColorStop(0, `rgba(${node.glowColor}, ${1 - breakProgress})`);
                nodeGlow.addColorStop(1, `rgba(${node.glowColor}, 0)`);
                nCtx.fillStyle = nodeGlow;
                nCtx.fill();
            });

            // Fade the solid background block out smoothly to reveal starry space
            entranceContainer.style.opacity = `${1 - breakProgress}`;
            entranceContainer.style.filter = `blur(${breakProgress * 15}px)`;

            if (breakProgress >= 1.0) {
                entranceContainer.style.visibility = 'hidden';
            } else {
                entranceContainer.style.visibility = 'visible';
            }

            /* 2. VSB TITLE FADE TIMELINE (Slower fade rate over 3.2 viewports, staying visible much longer) */
            const fadeMaxDistance = viewportHeight * 3.2; 
            const fadeProgress = Math.min(Math.max(interpolatedScrollY / fadeMaxDistance, 0), 1);
            const opacityValue = Math.max(1 - fadeProgress, 0);
            splashScreen.style.opacity = `${opacityValue}`;
            splashScreen.style.transform = `scale(${1 - (fadeProgress * 0.04)})`;

            // Toggle visibility to prevent background overlap
            if (opacityValue <= 0.002) {
                splashScreen.style.visibility = 'hidden';
            } else {
                splashScreen.style.visibility = 'visible';
            }

            /* 3. CONTENT REVEAL TIMELINE (Starts immediately after clouds open at 1.0, fully in at 2.5) */
            const contentStartScroll = viewportHeight * 1.0; 
            const contentEndScroll = viewportHeight * 2.5;   
            
            let contentProgress = (interpolatedScrollY - contentStartScroll) / (contentEndScroll - contentStartScroll);
            contentProgress = Math.min(Math.max(contentProgress, 0), 1);

            // Directly map calculated progress to transform matrix frames
            mainContent.style.opacity = `${contentProgress}`;
            mainContent.style.transform = `translateY(${(1 - contentProgress) * 50}px)`;

            requestAnimationFrame(updateParallaxFrames);
        }

        // Run animation engine
        requestAnimationFrame(updateParallaxFrames);
    </script>
</body>
</html>