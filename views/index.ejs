<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>V.S.B. Engineering College | Department of AI &amp; ML</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap');
        
        * {
            cursor: none !important;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #03000a;
            color: #f3f4f6;
            overflow-x: hidden;
        }

        .heading-font {
            font-family: 'Orbitron', sans-serif;
        }

        /* Starfield background */
        #starfield {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* Custom Cosmic Cursor Core */
        .custom-cursor {
            width: 12px;
            height: 12px;
            background: #06b6d4;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 10000;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 10px #06b6d4, 0 0 20px #2563eb;
            transition: transform 0.08s ease-out;
            will-change: transform;
        }

        .custom-cursor-trail {
            width: 6px;
            height: 6px;
            background: #2563eb;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%, -50%);
            opacity: 0.6;
            transition: transform 0.15s ease-out;
        }

        .galaxy-card {
            background: rgba(13, 8, 28, 0.8);
            border: 1px solid rgba(139, 92, 246, 0.2);
            backdrop-filter: blur(12px);
            transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        }

        .galaxy-card:hover {
            transform: translateY(-4px);
            border-color: rgba(6, 182, 212, 0.4);
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.15);
        }

        /* Glassmorphic Portal Nodes for Dashboard */
        .portal-node {
            background: rgba(13, 8, 28, 0.85);
            border: 1px solid rgba(6, 182, 212, 0.25);
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.05);
            backdrop-filter: blur(12px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            will-change: transform, border-color, box-shadow;
        }

        .portal-node:hover {
            border-color: #a855f7;
            box-shadow: 0 0 30px rgba(168, 85, 247, 0.3);
            transform: translateY(-4px);
        }

        @media (max-width: 640px) {
            /* Disable custom cursor on mobile touch screens to prevent lag */
            .custom-cursor, .custom-cursor-trail {
                display: none !important;
            }
            * {
                cursor: auto !important;
            }
        }
    </style>
</head>
<body class="bg-[#03000a]" data-logged-in="<%= !!user %>">

    <!-- Interactive Custom Cursor -->
    <div id="cursor-core" class="custom-cursor"></div>
    <div id="cursor-trail" class="custom-cursor-trail"></div>

    <!-- Cosmic Starfield Layer -->
    <canvas id="starfield"></canvas>

    <% if (!user) { %>
        <!-- ========================================================================
             1. PUBLIC VISITOR SCREEN (Locked: Direct Login Landing Page)
             ======================================================================== -->
        
        <div class="relative z-30 min-h-screen w-full flex flex-col items-center justify-center p-4 sm:p-6">
            
            <!-- VSB Header Details above the login card -->
            <div class="text-center mb-6 max-w-xl mx-auto">
                <div class="mb-4 flex justify-center">
                    <img src="/images/vsb-logo.png" alt="V.S.B. College Logo" class="w-20 h-20 sm:w-24 sm:h-28 object-contain drop-shadow-[0_0_15px_rgba(255,255,255,0.15)]">
                </div>
                <span class="heading-font text-[10px] sm:text-xs tracking-[0.25em] sm:tracking-[0.4em] uppercase text-cyan-400 block mb-2 font-semibold">V.S.B. Engineering College</span>
                <h1 class="heading-font text-2xl sm:text-4xl font-extrabold text-white tracking-wider leading-tight uppercase">
                    Artificial Intelligence &amp; <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400">Machine Learning</span>
                </h1>
                
                <!-- Accreditation Subtitle (Styled in Times New Roman) -->
                <p class="mt-3 text-xs sm:text-sm font-normal text-gray-400 leading-relaxed tracking-wide" style="font-family: 'Times New Roman', Times, serif;">
                    Affiliated to Anna University, Chennai &amp; Approved by AICTE, New Delhi
                </p>
            </div>

            <!-- Login Card Container -->
            <div class="w-full max-w-md galaxy-card p-6 sm:p-8 rounded-3xl">
                <!-- Tab Toggles -->
                <div class="flex border-b border-white/5 mb-6 text-xs sm:text-sm font-mono">
                    <button id="tab-login-btn" class="w-1/2 pb-3 border-b-2 border-cyan-400 text-white font-semibold focus:outline-none">Sign In</button>
                    <button id="tab-register-btn" class="w-1/2 pb-3 border-b-2 border-transparent text-gray-400 font-semibold focus:outline-none">Sign Up</button>
                </div>

                <!-- Client-Side Mismatch Alert Box -->
                <div id="register-error-box" class="hidden bg-red-950/50 border border-red-500/30 text-red-300 text-xs p-3 rounded-lg mb-6">
                    Passwords do not match. Please verify.
                </div>

                <!-- Sign In Form -->
                <form id="form-login" action="/login" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Email Address</label>
                        <input type="email" name="email" required placeholder="enter your email" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-xs sm:text-sm text-white focus:outline-none focus:border-cyan-400 transition">
                    </div>
                    <div>
                        <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Security Key (Password)</label>
                        <div class="relative">
                            <input type="password" id="signin-password" name="password" required placeholder="enter your password" class="w-full bg-black/40 border border-white/10 rounded-xl pl-4 pr-10 py-3 text-xs sm:text-sm text-white focus:outline-none focus:border-cyan-400 transition">
                            <button type="button" onclick="togglePasswordVisibility('signin-password', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white focus:outline-none">
                                <svg class="w-4 h-4 eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-3-3 3 3 0 013 3z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                <svg class="w-4 h-4 eye-closed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 113.382 3.382m0.792-3.382a3 3 0 11-1.104-1.104m3.52 3.52l3.52 3.52M3 3l18 18"></path></svg>
                            </button>
                        </div>
                        
                        <!-- Forgot Password Link -->
                        <div class="mt-2 text-right">
                            <a href="/forgot-password" class="text-[10px] text-cyan-400 hover:text-cyan-300 font-mono transition">Forgot Password?</a>
                        </div>
                    </div>
                    <button type="submit" class="w-full py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-xl text-xs sm:text-sm font-semibold transition mt-6 shadow-lg shadow-purple-600/20">
                        Authenticate User
                    </button>
                </form>

                <!-- Sign Up Form (With Year & Department Selectors) -->
                <form id="form-register" action="/register" method="POST" class="space-y-4 hidden text-xs sm:text-sm">
                    <div>
                        <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">College Email Address</label>
                        <input type="email" name="email" required placeholder="enter your email" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-400 transition">
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Academic Year</label>
                            <select name="year" required class="w-full bg-[#110b24] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-400 transition">
                                <option value="1st year">1st year</option>
                                <option value="2nd year">2nd year</option>
                                <option value="3rd year">3rd year</option>
                                <option value="4th year">4th year</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Department</label>
                            <select name="department" required class="w-full bg-[#110b24] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-400 transition">
                                <option value="CSE">CSE</option>
                                <option value="CSE(AIML)">CSE(AIML)</option>
                                <option value="CCE">CCE</option>
                                <option value="BIO MED">Bio Med</option>
                                <option value="CHEM">Chem</option>
                                <option value="MECH">Mech</option>
                                <option value="ECE">ECE</option>
                                <option value="EEE">EEE</option>
                                <option value="CIVIL">Civil</option>
                                <option value="CSBS">CSBS</option>
                                <option value="AIDS">AIDS</option>
                                <option value="BIO TECH">Bio Tech</option>
                                <option value="IT">IT</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Establish Security Password</label>
                        <div class="relative">
                            <input type="password" id="register-password" name="password" required placeholder="enter your password" class="w-full bg-black/40 border border-white/10 rounded-xl pl-4 pr-10 py-3 text-white focus:outline-none focus:border-purple-400 transition">
                            <button type="button" onclick="togglePasswordVisibility('register-password', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white focus:outline-none">
                                <svg class="w-4 h-4 eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-3-3 3 3 0 013 3z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                <svg class="w-4 h-4 eye-closed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 113.382 3.382m0.792-3.382a3 3 0 11-1.104-1.104m3.52 3.52l3.52 3.52M3 3l18 18"></path></svg>
                            </button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Confirm Security Password</label>
                        <div class="relative">
                            <input type="password" id="register-confirm" required placeholder="confirm your password" class="w-full bg-black/40 border border-white/10 rounded-xl pl-4 pr-10 py-3 text-white focus:outline-none focus:border-purple-400 transition">
                            <button type="button" onclick="togglePasswordVisibility('register-confirm', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white focus:outline-none">
                                <svg class="w-4 h-4 eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-3-3 3 3 0 013 3z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                <svg class="w-4 h-4 eye-closed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 113.382 3.382m0.792-3.382a3 3 0 11-1.104-1.104m3.52 3.52l3.52 3.52M3 3l18 18"></path></svg>
                            </button>
                        </div>
                    </div>
                    <button type="submit" class="w-full py-3 bg-cyan-600 hover:bg-cyan-700 text-white rounded-xl text-xs sm:text-sm font-semibold transition mt-6 shadow-lg shadow-cyan-600/20 font-mono">
                        Register Account
                    </button>
                </form>

                <!-- Google SSO Separator -->
                <div class="relative flex py-6 items-center">
                    <div class="flex-grow border-t border-white/10"></div>
                    <span class="flex-shrink mx-4 text-[10px] text-gray-500 uppercase tracking-widest font-mono">OR</span>
                    <div class="flex-grow border-t border-white/10"></div>
                </div>

                <!-- Google OAuth Redirect Button -->
                <a href="/auth/google" class="w-full py-3 bg-white hover:bg-gray-100 text-gray-900 rounded-xl text-xs font-semibold flex items-center justify-center space-x-3 transition shadow-lg shadow-white/5">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.18 1-.76 1.85-1.61 2.42v2.01h2.59c1.51-1.39 2.38-3.43 2.38-5.83z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.59-2.01c-1 .67-2.28 1.07-3.69 1.07-2.83 0-5.23-1.91-6.08-4.49H3.1v2.13C4.92 20.67 8.24 23 12 23z" fill="#34A853"/>
                        <path d="M5.92 14.91C5.7 14.25 5.58 13.55 5.58 12.8s.12-1.45.34-2.11V8.56H3.1C2.4 10 2 11.45 2 12.8s.4 2.8 1.1 4.24l2.82-2.13z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 8.24 1 4.92 3.33 3.1 6.67l2.82 2.13C6.77 7.29 9.17 5.38 12 5.38z" fill="#EA4335"/>
                    </svg>
                    <span class="text-gray-900 font-mono">Continue with Google</span>
                </a>
            </div>
        </div>
    <% } else { %>
        <!-- ========================================================================
             2. PRIVATE STUDENT DASHBOARD (Interconnected portals)
             ======================================================================== -->
        
        <!-- Global Navigation -->
        <nav class="fixed top-0 left-0 w-full z-40 bg-black/50 backdrop-blur-md border-b border-white/5 px-4 sm:px-6 py-3 sm:py-4 flex flex-col sm:flex-row justify-between items-center gap-3 sm:gap-0">
            <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
                <div class="flex items-center space-x-2 sm:space-x-3">
                    <img src="/images/vsb-logo.png" alt="V.S.B. Logo" class="w-6 h-6 sm:w-8 sm:h-8 object-contain">
                    <a href="/" class="heading-font text-xs sm:text-sm font-bold tracking-widest text-white">
                        V.S.B. AI &amp; ML
                    </a>
                </div>
                <div class="text-[8px] sm:text-[10px] text-gray-400 mt-1 font-normal tracking-wide leading-none max-w-[240px] sm:max-w-md" style="font-family: 'Times New Roman', Times, serif;">
                    Affiliated to Anna University, Chennai &amp; Approved by AICTE, New Delhi
                </div>
            </div>
            
            <div class="flex items-center space-x-6 text-xs font-mono">
                <% if (user.role === 'admin') { %>
                    <a href="/admin" class="text-yellow-400 hover:text-yellow-300 transition">Admin Console</a>
                <% } else { %>
                    <span class="text-purple-300 font-semibold"><%= user.email.split('@')[0] %> (Student)</span>
                    <a href="/logout" class="bg-red-950/40 border border-red-500/30 hover:bg-red-900/50 text-red-300 px-3 py-1 rounded transition">Sign Out</a>
                <% } %>
            </div>
        </nav>

        <!-- Interconnected portal dashboard -->
        <div class="relative w-screen min-h-screen flex items-center justify-center pt-24 pb-12 overflow-hidden">
            <div class="relative z-30 max-w-5xl mx-auto px-6 w-full">
                <div class="text-center mb-16">
                    <span class="text-xs uppercase font-mono tracking-widest text-cyan-400">[ SECURED INDEX CORE ]</span>
                    <h1 class="heading-font text-3xl sm:text-5xl font-extrabold text-white mt-2 uppercase">VSB AI &amp; ML Portal</h1>
                    <p class="text-gray-400 text-xs sm:text-sm mt-3 max-w-lg mx-auto">Select a terminal node below to explore active sub-systems.</p>
                </div>

                <!-- Triangular Interconnected Portal Nodes Grid -->
                <!-- Grid cols switches automatically based on role/permissions -->
                <div class="grid grid-cols-1 <%= (user.role === 'admin' || user.department === 'CSE(AIML)') ? 'md:grid-cols-3' : 'md:grid-cols-2' %> gap-8 relative max-w-4xl mx-auto">
                    
                    <!-- Node 1: Events -->
                    <a href="/events" class="portal-node p-8 rounded-3xl flex flex-col justify-between h-64 hover:scale-[1.03]">
                        <div>
                            <span class="text-[9px] font-mono tracking-widest text-cyan-400 block mb-2">[ SYSTEM 01 ]</span>
                            <h2 class="heading-font text-lg sm:text-xl font-bold text-white mb-3">EVENTS PORTAL</h2>
                            <p class="text-gray-400 text-xs leading-relaxed">Access active engineering symposiums, technical challenges, and live department hackathons.</p>
                        </div>
                        <span class="text-xs text-cyan-400 font-mono tracking-widest">[ ACCESS TERMINAL → ]</span>
                    </a>

                    <!-- Node 2: Academics (Conditionally Rendered ONLY for AIML students & Admins) -->
                    <% if (user.role === 'admin' || user.department === 'CSE(AIML)') { %>
                        <a href="/academics" class="portal-node p-8 rounded-3xl flex flex-col justify-between h-64 hover:scale-[1.03]">
                            <div>
                                <span class="text-[9px] font-mono tracking-widest text-purple-400 block mb-2">[ SYSTEM 02 ]</span>
                                <h2 class="heading-font text-lg sm:text-xl font-bold text-white mb-3">ACADEMIC UPDATES</h2>
                                <p class="text-gray-400 text-xs leading-relaxed">Review syllabus configurations, research paper submissions, and high-performance laboratory structures.</p>
                            </div>
                            <span class="text-xs text-purple-400 font-mono tracking-widest">[ ACCESS TERMINAL → ]</span>
                        </a>
                    <% } %>

                    <!-- Node 3: Announcements -->
                    <a href="/announcements" class="portal-node p-8 rounded-3xl flex flex-col justify-between h-64 hover:scale-[1.03]">
                        <div>
                            <span class="text-[9px] font-mono tracking-widest text-pink-400 block mb-2">[ SYSTEM 03 ]</span>
                            <h2 class="heading-font text-lg sm:text-xl font-bold text-white mb-3">ANNOUNCEMENTS</h2>
                            <p class="text-gray-400 text-xs leading-relaxed">Acquire official semester notifications, academic calendars, and real-time department alerts.</p>
                        </div>
                        <span class="text-xs text-pink-400 font-mono tracking-widest">[ ACCESS TERMINAL → ]</span>
                    </a>

                </div>
            </div>
        </div>

        <!-- Global Footer -->
        <footer class="border-t border-white/5 py-8 relative z-30 bg-black/60 text-center px-4">
            <p class="text-[10px] text-gray-500 font-normal">V.S.B. Engineering College, Karur, Tamil Nadu, India.</p>
            <p class="text-[9px] text-gray-600 mt-1">&copy; 2025 VSB Department of AI &amp; ML. All Rights Reserved.</p>
        </footer>
    <% } %>

    <!-- Scripting for Cursors, Stars, and Bidirectional Scroll Animations -->
    <script>
        // Custom Cursor Coordinate tracking
        const cursorCore = document.getElementById('cursor-core');
        let mouseX = 0;
        let mouseY = 0;

        document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            
            cursorCore.style.left = `${mouseX}px`;
            cursorCore.style.top = `${mouseY}px`;

            // Spawn Stardust particles on mouse move (only on desktop screens)
            if (window.innerWidth > 640 && Math.random() > 0.3) {
                spawnStardustParticle(mouseX, mouseY);
            }
        });

        // Hover enlargements
        document.querySelectorAll('a, button, .galaxy-card, .portal-node').forEach(element => {
            element.addEventListener('mouseenter', () => {
                cursorCore.style.transform = 'translate(-50%, -50%) scale(1.6)';
                cursorCore.style.backgroundColor = '#06b6d4';
            });
            element.addEventListener('mouseleave', () => {
                cursorCore.style.transform = 'translate(-50%, -50%) scale(1)';
                cursorCore.style.backgroundColor = '#06b6d4';
            });
        });

        // Canvas Stars & Stardust Particle Engine
        const canvas = document.getElementById('starfield');
        const ctx = canvas.getContext('2d');
        let stars = [];
        let stardustParticles = []; // Trailing stardust array

        function resizeStars() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            initializeStarsArray();
        }

        function initializeStarsArray() {
            stars = [];
            const count = Math.floor((canvas.width * canvas.height) / 7500);
            for (let i = 0; i < count; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    radius: Math.random() * 1.5,
                    brightness: Math.random(),
                    speed: 0.05 + Math.random() * 0.08
                });
            }
        }

        // Spawn a trailing particle
        function spawnStardustParticle(x, y) {
            stardustParticles.push({
                x: x,
                y: y,
                vx: (Math.random() - 0.5) * 1.5, 
                vy: (Math.random() - 0.5) * 1.5 + 0.5, 
                radius: 1 + Math.random() * 2,
                opacity: 1,
                decay: 0.015 + Math.random() * 0.015,
                color: Math.random() > 0.5 ? '168, 85, 247' : '6, 182, 212' // Purple or Cyan
            });
        }

        function drawStarsFrame() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#03000a';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Draw background stars
            stars.forEach(star => {
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 255, 255, ${star.brightness})`;
                ctx.fill();

                star.brightness += star.speed * (Math.random() - 0.5);
                if (star.brightness < 0.1) star.brightness = 0.1;
                if (star.brightness > 1) star.brightness = 1;
            });

            // Draw and update trailing cursor stardust
            for (let i = stardustParticles.length - 1; i >= 0; i--) {
                const p = stardustParticles[i];
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                
                const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius * 2);
                gradient.addColorStop(0, `rgba(${p.color}, ${p.opacity})`);
                gradient.addColorStop(1, `rgba(${p.color}, 0)`);
                
                ctx.fillStyle = gradient;
                ctx.fill();

                p.x += p.vx;
                p.y += p.vy;
                p.opacity -= p.decay;

                if (p.opacity <= 0) {
                    stardustParticles.splice(i, 1);
                }
            }

            requestAnimationFrame(drawStarsFrame);
        }

        window.addEventListener('resize', resizeStars);
        resizeStars();
        drawStarsFrame();

        /* 
           ========================================================================
           CLIENT-SIDE FORM CONTROLLER (Only runs if user is NOT logged in)
           ========================================================================
        */
        const isLoggedIn = document.body.getAttribute('data-logged-in') === 'true';

        if (!isLoggedIn) {
            const tabLoginBtn = document.getElementById('tab-login-btn');
            const tabRegisterBtn = document.getElementById('tab-register-btn');
            const formLogin = document.getElementById('form-login');
            const formRegister = document.getElementById('form-register');
            
            // Password verification variables
            const regPassword = document.getElementById('register-password');
            const regConfirm = document.getElementById('register-confirm');
            const regErrorBox = document.getElementById('register-error-box');

            // General password visibility toggle helper function
            function togglePasswordVisibility(inputId, button) {
                const input = document.getElementById(inputId);
                const openIcon = button.querySelector('.eye-open');
                const closedIcon = button.querySelector('.eye-closed');
                
                if (input.type === 'password') {
                    input.type = 'text';
                    openIcon.classList.add('hidden');
                    closedIcon.classList.remove('hidden');
                } else {
                    input.type = 'password';
                    openIcon.classList.remove('hidden');
                    closedIcon.classList.add('hidden');
                }
            }

            tabLoginBtn.addEventListener('click', () => {
                tabLoginBtn.classList.add('border-cyan-400', 'text-white');
                tabLoginBtn.classList.remove('border-transparent', 'text-gray-400');
                tabRegisterBtn.classList.add('border-transparent', 'text-gray-400');
                tabRegisterBtn.classList.remove('border-cyan-400', 'text-white');
                formLogin.classList.remove('hidden');
                formRegister.classList.add('hidden');
                regErrorBox.classList.add('hidden'); // Clear matching alerts on switch
            });

            tabRegisterBtn.addEventListener('click', () => {
                tabRegisterBtn.classList.add('border-cyan-400', 'text-white');
                tabRegisterBtn.classList.remove('border-transparent', 'text-gray-400');
                tabLoginBtn.classList.add('border-transparent', 'text-gray-400');
                tabLoginBtn.classList.remove('border-cyan-400', 'text-white');
                formRegister.classList.remove('hidden');
                formLogin.classList.add('hidden');
            });

            // Client-side verification during form submission
            formRegister.addEventListener('submit', (e) => {
                if (regPassword.value !== regConfirm.value) {
                    e.preventDefault(); // Stop form submission
                    regErrorBox.classList.remove('hidden'); // Display alert box
                    regConfirm.focus();
                } else {
                    regErrorBox.classList.add('hidden'); // Hide alert box
                }
            });
        }
    </script>
</body>
</html>