<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credentials Portal | V.S.B. Engineering College</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap');
        
        * {
            cursor: none !important;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: radial-gradient(circle at center, #0B001A 0%, #03000a 100%);
            color: #f3f4f6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .heading-font {
            font-family: 'Orbitron', sans-serif;
        }

        .galaxy-card {
            background: rgba(13, 8, 28, 0.85);
            border: 1px solid rgba(139, 92, 246, 0.25);
            backdrop-filter: blur(20px);
            box-shadow: 0 0 30px rgba(139, 92, 246, 0.15);
        }

        /* Custom Cosmic Cursor */
        .custom-cursor {
            width: 14px;
            height: 14px;
            background: #a855f7;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 10000;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 10px #a855f7, 0 0 20px #2563eb;
            transition: transform 0.08s ease-out;
        }

        @media (max-width: 640px) {
            .custom-cursor {
                display: none !important;
            }
            * {
                cursor: auto !important;
            }
        }
    </style>
</head>
<body class="p-4 sm:p-6">

    <!-- Active Custom Cursor -->
    <div id="cursor-core" class="custom-cursor"></div>

    <div class="w-full max-w-md galaxy-card p-6 sm:p-8 rounded-3xl">
        <div class="text-center mb-6 sm:mb-8">
            <div class="mb-4 flex justify-center">
                <img src="/images/vsb-logo.png" alt="V.S.B. Logo" class="w-12 h-12 sm:w-16 sm:h-16 object-contain">
            </div>
            <a href="/" class="heading-font text-[10px] tracking-widest text-cyan-400 hover:text-cyan-300 block mb-2">← Back to Portal</a>
            <h1 class="heading-font text-lg sm:text-xl font-bold tracking-wide">SECURE ACCESS GATE</h1>
            <p class="text-gray-400 text-[10px] sm:text-xs mt-1">V.S.B. Engineering College</p>
        </div>

        <!-- Alert Cards -->
        <% if (error) { %>
            <div class="bg-red-950/50 border border-red-500/30 text-red-300 text-xs p-3 rounded-lg mb-4 sm:mb-6">
                <%= error %>
            </div>
        <% } %>
        <% if (success) { %>
            <div class="bg-green-950/50 border border-green-500/30 text-green-300 text-xs p-3 rounded-lg mb-4 sm:mb-6">
                <%= success %>
            </div>
        <% } %>

        <!-- Client-Side Mismatch Alert Box -->
        <div id="register-error-box" class="hidden bg-red-950/50 border border-red-500/30 text-red-300 text-xs p-3 rounded-lg mb-4 sm:mb-6">
            Passwords do not match. Please verify.
        </div>

        <!-- Form Toggles -->
        <div class="flex border-b border-white/5 mb-6 text-xs sm:text-sm">
            <button id="tab-login-btn" class="w-1/2 pb-3 border-b-2 border-cyan-400 text-white font-semibold focus:outline-none">Sign In</button>
            <button id="tab-register-btn" class="w-1/2 pb-3 border-b-2 border-transparent text-gray-400 font-semibold focus:outline-none">Sign Up</button>
        </div>

        <!-- Sign In Form -->
        <form id="form-login" action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Email Address</label>
                <input type="email" name="email" required placeholder="enter your email" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-xs sm:text-sm text-white focus:outline-none focus:border-cyan-400 transition">
            </div>
            <div>
                <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Security Key (Password)</label>
                <div class="relative">
                    <input type="password" id="signin-password" name="password" required placeholder="enter your password" class="w-full bg-black/40 border border-white/10 rounded-xl pl-4 pr-10 py-3 text-xs sm:text-sm text-white focus:outline-none focus:border-cyan-400 transition">
                    <button type="button" onclick="togglePasswordVisibility('signin-password', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white focus:outline-none">
                        <!-- Eye Open SVG -->
                        <svg class="w-4 h-4 eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-3-3 3 3 0 013 3z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        <!-- Eye Closed SVG -->
                        <svg class="w-4 h-4 eye-closed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 113.382 3.382m0.792-3.382a3 3 0 11-1.104-1.104m3.52 3.52l3.52 3.52M3 3l18 18"></path></svg>
                    </button>
                </div>
                
                <!-- Forgot Password Link -->
                <div class="mt-2 text-right">
                    <a href="/forgot-password" class="text-[10px] text-cyan-400 hover:text-cyan-300 font-mono transition">Forgot Password?</a>
                </div>
            </div>

            <!-- Inline CAPTCHA Integration (Sign-In) -->
            <div class="bg-white/5 border border-white/5 p-4 rounded-xl space-y-3">
                <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider">Bot Protection Challenge</label>
                <div class="flex items-center space-x-3">
                    <img id="login-captcha-img" src="/captcha" alt="CAPTCHA" class="rounded-xl h-10 border border-white/10 cursor-pointer w-1/2 object-cover" onclick="this.src='/captcha?'+Date.now()" title="Click to Refresh">
                    <input type="text" name="captcha" required placeholder="enter code" class="w-1/2 bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-xs text-white uppercase tracking-widest focus:outline-none focus:border-cyan-400 transition text-center">
                </div>
                <span class="text-[8px] text-gray-500 block font-mono">Click the image code above to refresh.</span>
            </div>

            <button type="submit" class="w-full py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-xl text-xs sm:text-sm font-semibold transition mt-6 shadow-lg shadow-purple-600/20">
                Authenticate User
            </button>
        </form>

        <!-- Sign Up Form with Password Confirmation -->
        <form id="form-register" action="/register" method="POST" class="space-y-4 hidden">
            <div>
                <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">College Email Address</label>
                <input type="email" name="email" required placeholder="enter your email" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-xs sm:text-sm text-white focus:outline-none focus:border-purple-400 transition">
            </div>
            <div>
                <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Establish Security Password</label>
                <div class="relative">
                    <input type="password" id="register-password" name="password" required placeholder="enter your password" class="w-full bg-black/40 border border-white/10 rounded-xl pl-4 pr-10 py-3 text-xs sm:text-sm text-white focus:outline-none focus:border-purple-400 transition">
                    <button type="button" onclick="togglePasswordVisibility('register-password', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white focus:outline-none">
                        <!-- Eye Open SVG -->
                        <svg class="w-4 h-4 eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-3-3 3 3 0 013 3z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        <!-- Eye Closed SVG -->
                        <svg class="w-4 h-4 eye-closed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 113.382 3.382m0.792-3.382a3 3 0 11-1.104-1.104m3.52 3.52l3.52 3.52M3 3l18 18"></path></svg>
                    </button>
                </div>
            </div>
            <div>
                <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider mb-2">Confirm Security Password</label>
                <div class="relative">
                    <input type="password" id="register-confirm" required placeholder="confirm your password" class="w-full bg-black/40 border border-white/10 rounded-xl pl-4 pr-10 py-3 text-xs sm:text-sm text-white focus:outline-none focus:border-purple-400 transition">
                    <button type="button" onclick="togglePasswordVisibility('register-confirm', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white focus:outline-none">
                        <!-- Eye Open SVG -->
                        <svg class="w-4 h-4 eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-3-3 3 3 0 013 3z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        <!-- Eye Closed SVG -->
                        <svg class="w-4 h-4 eye-closed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 113.382 3.382m0.792-3.382a3 3 0 11-1.104-1.104m3.52 3.52l3.52 3.52M3 3l18 18"></path></svg>
                    </button>
                </div>
            </div>

            <!-- Inline CAPTCHA Integration (Sign-Up) -->
            <div class="bg-white/5 border border-white/5 p-4 rounded-xl space-y-3">
                <label class="block text-[10px] uppercase text-gray-400 font-semibold tracking-wider">Bot Protection Challenge</label>
                <div class="flex items-center space-x-3">
                    <img id="register-captcha-img" src="/captcha" alt="CAPTCHA" class="rounded-xl h-10 border border-white/10 cursor-pointer w-1/2 object-cover" onclick="this.src='/captcha?'+Date.now()" title="Click to Refresh">
                    <input type="text" name="captcha" required placeholder="enter code" class="w-1/2 bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-xs text-white uppercase tracking-widest focus:outline-none focus:border-purple-400 transition text-center">
                </div>
                <span class="text-[8px] text-gray-500 block font-mono">Click the image code above to refresh.</span>
            </div>

            <button type="submit" class="w-full py-3 bg-cyan-600 hover:bg-cyan-700 text-white rounded-xl text-xs sm:text-sm font-semibold transition mt-6 shadow-lg shadow-cyan-600/20">
                Register Account
            </button>
        </form>

        <!-- Google SSO Separator -->
        <div class="relative flex py-6 items-center">
            <div class="flex-grow border-t border-white/10"></div>
            <span class="flex-shrink mx-4 text-[10px] text-gray-500 uppercase tracking-widest font-mono">OR</span>
            <div class="flex-grow border-t border-white/10"></div>
        </div>

        <!-- Google OAuth Redirect Button -->
        <a href="/auth/google" class="w-full py-3 bg-white hover:bg-gray-100 text-gray-900 rounded-xl text-xs font-semibold flex items-center justify-center space-x-3 transition shadow-lg shadow-white/5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.18 1-.76 1.85-1.61 2.42v2.01h2.59c1.51-1.39 2.38-3.43 2.38-5.83z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.59-2.01c-1 .67-2.28 1.07-3.69 1.07-2.83 0-5.23-1.91-6.08-4.49H3.1v2.13C4.92 20.67 8.24 23 12 23z" fill="#34A853"/>
                <path d="M5.92 14.91C5.7 14.25 5.58 13.55 5.58 12.8s.12-1.45.34-2.11V8.56H3.1C2.4 10 2 11.45 2 12.8s.4 2.8 1.1 4.24l2.82-2.13z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 8.24 1 4.92 3.33 3.1 6.67l2.82 2.13C6.77 7.29 9.17 5.38 12 5.38z" fill="#EA4335"/>
            </svg>
            <span class="text-gray-900">Continue with Google</span>
        </a>
    </div>

    <!-- Interface Controller -->
    <script>
        const cursor = document.getElementById('cursor-core');
        document.addEventListener('mousemove', (e) => {
            if (window.innerWidth > 640) {
                cursor.style.left = `${e.clientX}px`;
                cursor.style.top = `${e.clientY}px`;
            }
        });

        const tabLoginBtn = document.getElementById('tab-login-btn');
        const tabRegisterBtn = document.getElementById('tab-register-btn');
        const formLogin = document.getElementById('form-login');
        const formRegister = document.getElementById('form-register');
        
        // Password verification variables
        const regPassword = document.getElementById('register-password');
        const regConfirm = document.getElementById('register-confirm');
        const regErrorBox = document.getElementById('register-error-box');

        // General password visibility toggle helper function
        function togglePasswordVisibility(inputId, button) {
            const input = document.getElementById(inputId);
            const openIcon = button.querySelector('.eye-open');
            const closedIcon = button.querySelector('.eye-closed');
            
            if (input.type === 'password') {
                input.type = 'text';
                openIcon.classList.add('hidden');
                closedIcon.classList.remove('hidden');
            } else {
                input.type = 'password';
                openIcon.classList.remove('hidden');
                closedIcon.classList.add('hidden');
            }
        }

        tabLoginBtn.addEventListener('click', () => {
            tabLoginBtn.classList.add('border-cyan-400', 'text-white');
            tabLoginBtn.classList.remove('border-transparent', 'text-gray-400');
            tabRegisterBtn.classList.add('border-transparent', 'text-gray-400');
            tabRegisterBtn.classList.remove('border-cyan-400', 'text-white');
            formLogin.classList.remove('hidden');
            formRegister.classList.add('hidden');
            regErrorBox.classList.add('hidden'); // Clear matching alerts on switch
            
            // Refresh login CAPTCHA code on tab switch
            document.getElementById('login-captcha-img').src = '/captcha?' + Date.now();
        });

        tabRegisterBtn.addEventListener('click', () => {
            tabRegisterBtn.classList.add('border-cyan-400', 'text-white');
            tabRegisterBtn.classList.remove('border-transparent', 'text-gray-400');
            tabLoginBtn.classList.add('border-transparent', 'text-gray-400');
            tabLoginBtn.classList.remove('border-cyan-400', 'text-white');
            formRegister.classList.remove('hidden');
            formLogin.classList.add('hidden');
            
            // Refresh register CAPTCHA code on tab switch
            document.getElementById('register-captcha-img').src = '/captcha?' + Date.now();
        });

        // Client-side verification during form submission
        formRegister.addEventListener('submit', (e) => {
            if (regPassword.value !== regConfirm.value) {
                e.preventDefault(); // Stop form submission
                regErrorBox.classList.remove('hidden'); // Display alert box
                regConfirm.focus();
            } else {
                regErrorBox.classList.add('hidden'); // Hide alert box
            }
        });
    </script>
</body>
</html>