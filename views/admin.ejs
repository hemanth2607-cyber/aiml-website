<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Console | V.S.B. Engineering College</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap');
        
        * {
            cursor: none !important;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #03000a;
            color: #f3f4f6;
        }

        .heading-font {
            font-family: 'Orbitron', sans-serif;
        }

        .admin-card {
            background: rgba(13, 8, 28, 0.75);
            border: 1px solid rgba(139, 92, 246, 0.2);
            backdrop-filter: blur(12px);
        }

        /* Custom Cosmic Cursor */
        .custom-cursor {
            width: 14px;
            height: 14px;
            background: #a855f7;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 10000;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 10px #a855f7, 0 0 20px #2563eb;
            transition: transform 0.08s ease-out;
        }
    </style>
</head>
<body class="p-6 md:p-12 min-h-screen">

    <!-- Active Tracking Cursor -->
    <div id="cursor-core" class="custom-cursor"></div>

    <div class="max-w-6xl mx-auto">
        
        <!-- Header Controls -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-4">
            <div class="flex items-center space-x-4">
                <img src="/images/vsb-logo.png" alt="V.S.B. Logo" class="w-12 h-12 object-contain">
                <div>
                    <a href="/" class="heading-font text-xs tracking-widest text-cyan-400 hover:text-cyan-300 block mb-1">← Return to Main Portal</a>
                    <h1 class="heading-font text-2xl font-black text-white tracking-wider">
                        ADMIN REGISTRY &amp; BLOG CONTROL PANEL
                    </h1>
                </div>
            </div>
            <a href="/logout" class="bg-red-950/40 border border-red-500/30 hover:bg-red-900/50 text-red-300 text-xs px-4 py-2 rounded-xl transition">Sign Out</a>
        </div>

        <!-- CRUD Interface: Blog Management Form -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
            
            <div class="lg:col-span-1 admin-card p-6 rounded-2xl h-fit">
                <h2 class="heading-font text-sm font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-6 uppercase">
                    <%= editBlog ? 'Modify Academic Log' : 'Publish Academic Log' %>
                </h2>
                
                <form action="<%= editBlog ? '/admin/blogs/update/' + editBlog.id : '/admin/blogs/add' %>" method="POST" class="space-y-4 text-xs">
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">UPDATE / BLOG TITLE</label>
                        <input type="text" name="title" required value="<%= editBlog ? editBlog.title : '' %>" placeholder="e.g., Semester Practical Exam Labs" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">CATEGORY</label>
                        <select name="category" class="w-full bg-[#130d24] border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition">
                            <option value="Lab Updates" <%= editBlog && editBlog.category === 'Lab Updates' ? 'selected' : '' %>>Lab Updates</option>
                            <option value="Academic" <%= editBlog && editBlog.category === 'Academic' ? 'selected' : '' %>>Academic</option>
                            <option value="Research" <%= editBlog && editBlog.category === 'Research' ? 'selected' : '' %>>Research</option>
                            <option value="Syllabus" <%= editBlog && editBlog.category === 'Syllabus' ? 'selected' : '' %>>Syllabus</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">SHORT BRIEF (SUMMARY)</label>
                        <textarea name="summary" required rows="3" placeholder="Brief summary of the update..." class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition"><%= editBlog ? editBlog.summary : '' %></textarea>
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">DETAILED LOG (CONTENT)</label>
                        <textarea name="content" required rows="5" placeholder="Full academic or laboratory content here..." class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition"><%= editBlog ? editBlog.content : '' %></textarea>
                    </div>
                    <div class="flex space-x-2 pt-2">
                        <button type="submit" class="flex-1 py-2 bg-gradient-to-tr from-purple-600 to-cyan-500 hover:from-purple-500 hover:to-cyan-400 text-white font-bold rounded-xl transition">
                            <%= editBlog ? 'Update Entry' : 'Save & Publish' %>
                        </button>
                        <% if (editBlog) { %>
                            <a href="/admin" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 font-bold rounded-xl transition flex items-center">Cancel</a>
                        <% } %>
                    </div>
                </form>
            </div>

            <!-- Published Department Updates Table list -->
            <div class="lg:col-span-2 admin-card rounded-2xl overflow-hidden h-fit">
                <div class="px-6 py-4 border-b border-white/5 bg-white/5">
                    <h3 class="heading-font text-sm font-bold text-white uppercase">Department Updates Registry</h3>
                </div>
                <div class="overflow-x-auto text-xs">
                    <table class="w-full text-left text-gray-300">
                        <thead class="bg-black/40 border-b border-white/5 text-gray-400 font-mono">
                            <tr>
                                <th class="px-6 py-3">Category</th>
                                <th class="px-6 py-3">Title</th>
                                <th class="px-6 py-3">Date</th>
                                <th class="px-6 py-3 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <% if (blogs && blogs.length > 0) { %>
                                <% blogs.forEach(blog => { %>
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="px-6 py-4">
                                            <span class="px-2 py-0.5 border border-purple-500/20 text-purple-300 bg-purple-950/20 rounded-full font-mono">
                                                <%= blog.category %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 font-semibold text-white"><%= blog.title %></td>
                                        <td class="px-6 py-4 font-mono text-gray-400"><%= blog.date %></td>
                                        <td class="px-6 py-4 text-right space-x-2 font-mono">
                                            <a href="/admin/edit/<%= blog.id %>" class="text-cyan-400 hover:text-cyan-300 transition">Edit</a>
                                            <span class="text-gray-700">|</span>
                                            <a href="/admin/blogs/delete/<%= blog.id %>" onclick="return confirm('Confirm entry deletion?');" class="text-red-400 hover:text-red-300 transition">Delete</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="px-6 py-8 text-center text-gray-500 font-mono">No entries active inside data structures.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <!-- Secured Student Telemetry Table -->
        <div class="admin-card rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-white/5 bg-white/5">
                <h2 class="heading-font text-sm font-bold text-white uppercase">V.S.B. Registered Student Accounts</h2>
            </div>
            <div class="overflow-x-auto text-xs">
                <table class="w-full text-left text-gray-300">
                    <thead class="uppercase text-gray-400 tracking-wider bg-black/40 border-b border-white/5 font-mono">
                        <tr>
                            <th class="px-6 py-4">System ID</th>
                            <th class="px-6 py-4">Student Email (VSB Domain)</th>
                            <th class="px-6 py-4">Database Access Role</th>
                            <th class="px-6 py-4">Registration Stamp</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% if (students && students.length > 0) { %>
                            <% students.forEach(student => { %>
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="px-6 py-4 font-mono text-cyan-400"><%= student.id %></td>
                                    <td class="px-6 py-4 text-white font-medium"><%= student.email %></td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-0.5 bg-blue-900/40 border border-blue-500/20 text-blue-300 rounded-full font-mono">
                                            <%= student.role %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-gray-400 font-mono"><%= student.created_at %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="px-6 py-8 text-center text-gray-500 font-mono">No verified students registered on this database interface.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- Active Tracker script -->
    <script>
        const cursor = document.getElementById('cursor-core');
        document.addEventListener('mousemove', (e) => {
            cursor.style.left = `${e.clientX}px`;
            cursor.style.top = `${e.clientY}px`;
        });
    </script>
</body>
</html>