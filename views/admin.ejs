<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Console | V.S.B. Engineering College</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap');
        
        * {
            cursor: none !important;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #03000a;
            color: #f3f4f6;
        }

        .heading-font {
            font-family: 'Orbitron', sans-serif;
        }

        .admin-card {
            background: rgba(13, 8, 28, 0.75);
            border: 1px solid rgba(139, 92, 246, 0.2);
            backdrop-filter: blur(12px);
        }

        /* Custom Cosmic Cursor */
        .custom-cursor {
            width: 14px;
            height: 14px;
            background: #a855f7;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 10000;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 10px #a855f7, 0 0 20px #2563eb;
            transition: transform 0.08s ease-out;
        }

        @media (max-width: 640px) {
            .custom-cursor {
                display: none !important;
            }
            * {
                cursor: auto !important;
            }
        }
    </style>
</head>
<body class="p-4 sm:p-6 md:p-12 min-h-screen">

    <!-- Active Tracking Cursor -->
    <div id="cursor-core" class="custom-cursor"></div>

    <div class="max-w-6xl mx-auto">
        
        <!-- Header Controls -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 sm:mb-12 gap-4">
            <div class="flex items-center space-x-3 sm:space-x-4">
                <img src="/images/vsb-logo.png" alt="V.S.B. Logo" class="w-10 h-10 sm:w-12 sm:h-12 object-contain">
                <div>
                    <a href="/" class="heading-font text-[9px] sm:text-xs tracking-widest text-cyan-400 hover:text-cyan-300 block mb-1">← Return to Main Portal</a>
                    <h1 class="heading-font text-base sm:text-xl md:text-2xl font-black text-white tracking-wider uppercase">
                        ADMIN CONTROL PANEL
                    </h1>
                </div>
            </div>
            <a href="/logout" class="bg-red-950/40 border border-red-500/30 hover:bg-red-900/50 text-red-300 text-[10px] sm:text-xs px-3 py-1.5 sm:px-4 sm:py-2 rounded-xl transition self-end md:self-auto">Sign Out</a>
        </div>

        <!-- Success & Error Alert Banners -->
        <% if (success) { %>
            <div class="bg-green-950/50 border border-green-500/30 text-green-300 text-xs p-4 rounded-xl mb-6">
                <%= success %>
            </div>
        <% } %>
        <% if (error) { %>
            <div class="bg-red-950/50 border border-red-500/30 text-red-300 text-xs p-4 rounded-xl mb-6">
                <%= error %>
            </div>
        <% } %>

        <!-- Telemetry Statistics Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 sm:gap-6 mb-8 sm:mb-12">
            <div class="admin-card p-5 sm:p-6 rounded-2xl">
                <span class="text-[10px] text-gray-400 font-mono block mb-1">Student Entities</span>
                <span class="heading-font text-2xl sm:text-3xl font-bold text-cyan-400"><%= students.length %></span>
            </div>
            <div class="admin-card p-5 sm:p-6 rounded-2xl">
                <span class="text-[10px] text-gray-400 font-mono block mb-1">Staff Entities</span>
                <span class="heading-font text-2xl sm:text-3xl font-bold text-cyan-400"><%= staff.length %></span>
            </div>
            <div class="admin-card p-5 sm:p-6 rounded-2xl">
                <span class="text-[10px] text-gray-400 font-mono block mb-1">Event Registrations</span>
                <span class="heading-font text-2xl sm:text-3xl font-bold text-pink-400"><%= registrations.length %></span>
            </div>
            <div class="admin-card p-5 sm:p-6 rounded-2xl">
                <span class="text-[10px] text-gray-400 font-mono block mb-1">Database Engine</span>
                <span class="heading-font text-2xl sm:text-3xl font-bold text-purple-400">PostgreSQL</span>
            </div>
        </div>

        <!-- Admin Tabbed Navigation -->
        <div class="flex border-b border-white/5 mb-8 text-xs sm:text-sm font-mono overflow-x-auto whitespace-nowrap gap-4">
            <button onclick="switchAdminTab('tab-announcements')" id="btn-tab-announcements" class="pb-3 border-b-2 border-cyan-400 text-white font-semibold focus:outline-none">Announcements</button>
            <button onclick="switchAdminTab('tab-academics')" id="btn-tab-academics" class="pb-3 border-b-2 border-transparent text-gray-400 font-semibold focus:outline-none">Academic Logs</button>
            <button onclick="switchAdminTab('tab-events')" id="btn-tab-events" class="pb-3 border-b-2 border-transparent text-gray-400 font-semibold focus:outline-none">Events</button>
            <button onclick="switchAdminTab('tab-registrations')" id="btn-tab-registrations" class="pb-3 border-b-2 border-transparent text-gray-400 font-semibold focus:outline-none">Registrations</button>
            <button onclick="switchAdminTab('tab-staff')" id="btn-tab-staff" class="pb-3 border-b-2 border-transparent text-gray-400 font-semibold focus:outline-none">Manage Staff</button>
            <button onclick="switchAdminTab('tab-notify')" id="btn-tab-notify" class="pb-3 border-b-2 border-transparent text-gray-400 font-semibold focus:outline-none">Send Email</button>
        </div>

        <!-- ========================================================================
             TAB 1: ANNOUNCEMENTS MANAGEMENT
             ======================================================================== -->
        <div id="tab-announcements" class="admin-tab-content grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-12">
            <!-- Create/Edit Form -->
            <div class="lg:col-span-1 admin-card p-5 sm:p-6 rounded-2xl h-fit">
                <h2 class="heading-font text-xs sm:text-sm font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-6 uppercase">
                    <%= editBlog ? 'Modify Announcement' : 'Publish Announcement' %>
                </h2>
                <form action="<%= editBlog ? '/admin/blogs/update/' + editBlog.id : '/admin/blogs/add' %>" method="POST" class="space-y-4 text-xs">
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">TITLE</label>
                        <input type="text" name="title" required value="<%= editBlog ? editBlog.title : '' %>" placeholder="e.g., Semester Exam Timetable" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">CATEGORY</label>
                        <select name="category" class="w-full bg-[#130d24] border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                            <option value="Notification" <%= editBlog && editBlog.category === 'Notification' ? 'selected' : '' %>>Notification</option>
                            <option value="Lab Updates" <%= editBlog && editBlog.category === 'Lab Updates' ? 'selected' : '' %>>Lab Updates</option>
                            <option value="General Alert" <%= editBlog && editBlog.category === 'General Alert' ? 'selected' : '' %>>General Alert</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">SUMMARY</label>
                        <textarea name="summary" required rows="3" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none"><%= editBlog ? editBlog.summary : '' %></textarea>
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">CONTENT</label>
                        <textarea name="content" required rows="5" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none"><%= editBlog ? editBlog.content : '' %></textarea>
                    </div>
                    <button type="submit" class="w-full py-2 bg-purple-600 text-white font-bold rounded-xl transition"><%= editBlog ? 'Update' : 'Publish' %></button>
                </form>
            </div>
            <!-- Lists Table -->
            <div class="lg:col-span-2 admin-card rounded-2xl overflow-hidden h-fit">
                <div class="px-6 py-4 border-b border-white/5 bg-white/5">
                    <h3 class="heading-font text-xs sm:text-sm font-bold text-white uppercase">Announcements Index</h3>
                </div>
                <div class="overflow-x-auto text-[10px] sm:text-xs">
                    <table class="w-full text-left text-gray-300 min-w-[300px]">
                        <tbody class="divide-y divide-white/5">
                            <% if (blogs && blogs.length > 0) { %>
                                <% blogs.forEach(item => { %>
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="px-4 py-4 font-semibold text-white">
                                            <span class="text-[9px] block text-purple-400 font-mono"><%= item.category %></span>
                                            <%= item.title %>
                                        </td>
                                        <td class="px-4 py-4 text-right space-x-2 font-mono whitespace-nowrap">
                                            <a href="/admin/edit/<%= item.id %>" class="text-cyan-400 hover:text-cyan-300">Edit</a>
                                            <span class="text-gray-700">|</span>
                                            <a href="/admin/blogs/delete/<%= item.id %>" onclick="return confirm('Confirm?');" class="text-red-400">Del</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="2" class="px-4 py-8 text-center text-gray-500 font-mono">No announcements.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ========================================================================
             TAB 2: ACADEMIC LOGS MANAGEMENT
             ======================================================================== -->
        <div id="tab-academics" class="admin-tab-content hidden grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-12">
            <!-- Create/Edit Form -->
            <div class="lg:col-span-1 admin-card p-5 sm:p-6 rounded-2xl h-fit">
                <h2 class="heading-font text-xs sm:text-sm font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-6 uppercase">
                    Publish Academic Log
                </h2>
                <form action="/admin/academics/add" method="POST" class="space-y-4 text-xs">
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">CURRICULUM / LAB TITLE</label>
                        <input type="text" name="title" required placeholder="e.g., Semester Neural Networks Syllabus" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">CATEGORY</label>
                        <select name="category" class="w-full bg-[#130d24] border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                            <option value="Syllabus">Syllabus</option>
                            <option value="Lab Work">Lab Work</option>
                            <option value="Research Papers">Research Papers</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">SUMMARY</label>
                        <textarea name="summary" required rows="3" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none"></textarea>
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">CONTENT</label>
                        <textarea name="content" required rows="5" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none"></textarea>
                    </div>
                    <button type="submit" class="w-full py-2 bg-purple-600 text-white font-bold rounded-xl transition">Publish Log</button>
                </form>
            </div>
            <!-- Lists Table -->
            <div class="lg:col-span-2 admin-card rounded-2xl overflow-hidden h-fit">
                <div class="px-6 py-4 border-b border-white/5 bg-white/5">
                    <h3 class="heading-font text-xs sm:text-sm font-bold text-white uppercase">Academic Logs Index</h3>
                </div>
                <div class="overflow-x-auto text-[10px] sm:text-xs">
                    <table class="w-full text-left text-gray-300 min-w-[300px]">
                        <tbody class="divide-y divide-white/5">
                            <% if (academics && academics.length > 0) { %>
                                <% academics.forEach(item => { %>
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="px-4 py-4 font-semibold text-white">
                                            <span class="text-[9px] block text-purple-400 font-mono"><%= item.category %></span>
                                            <%= item.title %>
                                        </td>
                                        <td class="px-4 py-4 text-right space-x-2 font-mono whitespace-nowrap">
                                            <a href="/admin/academics/delete/<%= item.id %>" onclick="return confirm('Confirm?');" class="text-red-400">Delete</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="2" class="px-4 py-8 text-center text-gray-500 font-mono">No academic logs.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ========================================================================
             TAB 3: EVENTS MANAGEMENT
             ======================================================================== -->
        <div id="tab-events" class="admin-tab-content hidden grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-12">
            <!-- Create/Edit Form -->
            <div class="lg:col-span-1 admin-card p-5 sm:p-6 rounded-2xl h-fit">
                <h2 class="heading-font text-xs sm:text-sm font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-6 uppercase">
                    Publish Event
                </h2>
                <form action="/admin/events/add" method="POST" class="space-y-4 text-xs">
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">EVENT TITLE</label>
                        <input type="text" name="title" required placeholder="e.g., National AI Hackathon" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">EVENT DATE</label>
                        <input type="text" name="date" required placeholder="e.g., Dec 12, 2025" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">LOCATION / HALL</label>
                        <input type="text" name="location" required placeholder="e.g., Main Auditorium" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">REGISTRATION LINK</label>
                        <input type="text" name="registration_link" placeholder="e.g., https://forms.gle/..." class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">EVENT BRIEF (SUMMARY)</label>
                        <textarea name="summary" required rows="4" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none"></textarea>
                    </div>
                    <button type="submit" class="w-full py-2 bg-purple-600 text-white font-bold rounded-xl transition">Publish Event</button>
                </form>
            </div>
            <!-- Lists Table -->
            <div class="lg:col-span-2 admin-card rounded-2xl overflow-hidden h-fit">
                <div class="px-6 py-4 border-b border-white/5 bg-white/5">
                    <h3 class="heading-font text-xs sm:text-sm font-bold text-white uppercase">Events Index</h3>
                </div>
                <div class="overflow-x-auto text-[10px] sm:text-xs">
                    <table class="w-full text-left text-gray-300 min-w-[300px]">
                        <tbody class="divide-y divide-white/5">
                            <% if (events && events.length > 0) { %>
                                <% events.forEach(item => { %>
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="px-4 py-4 font-semibold text-white">
                                            <span class="text-[9px] block text-purple-400 font-mono"><%= item.location %> | <%= item.date %></span>
                                            <%= item.title %>
                                        </td>
                                        <td class="px-4 py-4 text-right space-x-2 font-mono whitespace-nowrap">
                                            <a href="/admin/events/delete/<%= item.id %>" onclick="return confirm('Confirm?');" class="text-red-400">Delete</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="2" class="px-4 py-8 text-center text-gray-500 font-mono">No events.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ========================================================================
             TAB 4: REGISTRATIONS DIRECTORY & CRUD (Excel Exporter Integrated)
             ======================================================================== -->
        <div id="tab-registrations" class="admin-tab-content hidden grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-12">
            <!-- Add / Edit Registration Form -->
            <div class="lg:col-span-1 admin-card p-5 sm:p-6 rounded-2xl h-fit">
                <h2 class="heading-font text-xs sm:text-sm font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-6 uppercase">
                    <%= editRegistration ? 'Modify Registration' : 'Create Registration' %>
                </h2>
                <form action="<%= editRegistration ? '/admin/registrations/update/' + editRegistration.id : '/admin/registrations/add' %>" method="POST" class="space-y-4 text-xs">
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">STUDENT NAME</label>
                        <input type="text" name="name" required value="<%= editRegistration ? editRegistration.name : '' %>" placeholder="e.g. Hemanth Kumar" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">EMAIL ADDRESS</label>
                        <input type="email" name="email" required value="<%= editRegistration ? editRegistration.email : '' %>" placeholder="e.g. name@vsb.edu" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-gray-400 font-mono mb-1">YEAR</label>
                            <select name="year" class="w-full bg-[#130d24] border border-white/10 rounded-xl px-2 py-2 text-white focus:outline-none">
                                <option value="1st year" <%= editRegistration && editRegistration.year === '1st year' ? 'selected' : '' %>>1st year</option>
                                <option value="2nd year" <%= editRegistration && editRegistration.year === '2nd year' ? 'selected' : '' %>>2nd year</option>
                                <option value="3rd year" <%= editRegistration && editRegistration.year === '3rd year' ? 'selected' : '' %>>3rd year</option>
                                <option value="4th year" <%= editRegistration && editRegistration.year === '4th year' ? 'selected' : '' %>>4th year</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-400 font-mono mb-1">DEPARTMENT</label>
                            <select name="department" class="w-full bg-[#130d24] border border-white/10 rounded-xl px-2 py-2 text-white focus:outline-none">
                                <option value="CSE(AIML)" <%= editRegistration && editRegistration.department === 'CSE(AIML)' ? 'selected' : '' %>>CSE(AIML)</option>
                                <option value="CSE" <%= editRegistration && editRegistration.department === 'CSE' ? 'selected' : '' %>>CSE</option>
                                <option value="IT" <%= editRegistration && editRegistration.department === 'IT' ? 'selected' : '' %>>IT</option>
                                <option value="ECE" <%= editRegistration && editRegistration.department === 'ECE' ? 'selected' : '' %>>ECE</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">COLLEGE / INSTITUTION</label>
                        <input type="text" name="college" required value="<%= editRegistration ? editRegistration.college : 'VSB Engineering College' %>" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">EVENT NAME</label>
                        <select name="eventName" class="w-full bg-[#130d24] border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                            <% if (events && events.length > 0) { %>
                                <% events.forEach(e => { %>
                                    <option value="<%= e.title %>" <%= editRegistration && editRegistration.event_name === e.title ? 'selected' : '' %>><%= e.title %></option>
                                <% }) %>
                            <% } else { %>
                                <option value="No Events">No Active Events</option>
                            <% } %>
                        </select>
                    </div>
                    <div class="flex space-x-2 pt-2">
                        <button type="submit" class="flex-1 py-2 bg-gradient-to-tr from-purple-600 to-cyan-500 text-white font-bold rounded-xl transition">
                            <%= editRegistration ? 'Update Entry' : 'Create Entry' %>
                        </button>
                        <% if (editRegistration) { %>
                            <a href="/admin?tab=registrations" class="px-4 py-2 bg-gray-800 text-gray-300 font-bold rounded-xl transition flex items-center">Cancel</a>
                        <% } %>
                    </div>
                </form>
            </div>

            <!-- Registrations Directory Table -->
            <div class="lg:col-span-2 admin-card rounded-2xl overflow-hidden h-fit flex flex-col justify-between">
                <div>
                    <div class="px-6 py-4 border-b border-white/5 bg-white/5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                        <h3 class="heading-font text-xs sm:text-sm font-bold text-white uppercase">Registrations Database</h3>
                        
                        <!-- Client-Side Excel Exporter button -->
                        <button onclick="exportRegistrationsToCSV()" class="bg-emerald-950/40 border border-emerald-500/30 hover:bg-emerald-900/50 text-emerald-300 text-[10px] sm:text-xs px-3 py-1.5 rounded-xl transition font-mono flex items-center space-x-1.5">
                            <span>Download Excel Report</span>
                        </button>
                    </div>
                    <div class="overflow-x-auto text-[10px] sm:text-xs">
                        <table class="w-full text-left text-gray-300 min-w-[500px]">
                            <thead class="bg-black/40 border-b border-white/5 text-gray-400 font-mono">
                                <tr>
                                    <th class="px-4 py-3">Pass ID</th>
                                    <th class="px-4 py-3">Name</th>
                                    <th class="px-4 py-3">Email</th>
                                    <th class="px-4 py-3">Event</th>
                                    <th class="px-4 py-3 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="registrations-table-body" class="divide-y divide-white/5">
                                <% if (registrations && registrations.length > 0) { %>
                                    <% registrations.forEach(reg => { %>
                                        <tr class="hover:bg-white/5 transition-colors">
                                            <td class="px-4 py-4 font-mono text-cyan-400"><%= reg.ticket_id %></td>
                                            <td class="px-4 py-4 font-bold text-white"><%= reg.name %></td>
                                            <td class="px-4 py-4"><%= reg.email %></td>
                                            <td class="px-4 py-4 text-purple-300"><%= reg.event_name %></td>
                                            <!-- Additional fields hidden but captured by Excel exporter -->
                                            <td class="hidden"><%= reg.year %></td>
                                            <td class="hidden"><%= reg.department %></td>
                                            <td class="hidden"><%= reg.college %></td>
                                            <td class="hidden"><%= reg.created_at %></td>
                                            
                                            <td class="px-4 py-4 text-right space-x-2 font-mono whitespace-nowrap">
                                                <a href="/admin?editRegId=<%= reg.id %>&tab=registrations" class="text-cyan-400">Edit</a>
                                                <span class="text-gray-700">|</span>
                                                <a href="/admin/registrations/delete/<%= reg.id %>" onclick="return confirm('Are you sure?');" class="text-red-400">Delete</a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="5" class="px-4 py-8 text-center text-gray-500 font-mono">No active event registrations in the database.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- ========================================================================
             TAB 5: MANAGE STAFF ACCOUNTS (Staff Registry and creation)
             ======================================================================== -->
        <div id="tab-staff" class="admin-tab-content hidden grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-12">
            <!-- Create Staff Form -->
            <div class="lg:col-span-1 admin-card p-5 sm:p-6 rounded-2xl h-fit">
                <h2 class="heading-font text-xs sm:text-sm font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-6 uppercase">
                    Register Staff Account
                </h2>
                <form action="/admin/staff/add" method="POST" class="space-y-4 text-xs">
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">STAFF EMAIL (VSB DOMAIN)</label>
                        <input type="email" name="email" required placeholder="staffname@vsb.edu" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">TEMPORARY PASSWORD</label>
                        <input type="password" name="password" required placeholder="enter password" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition">
                    </div>
                    <div>
                        <label class="block text-gray-400 font-mono mb-1">DEPARTMENT</label>
                        <select name="department" required class="w-full bg-[#130d24] border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition">
                            <option value="CSE">CSE</option>
                            <option value="CSE(AIML)">CSE(AIML)</option>
                            <option value="CCE">CCE</option>
                            <option value="Bio Med">Bio Med</option>
                            <option value="Chem">Chem</option>
                            <option value="Mech">Mech</option>
                            <option value="ECE">ECE</option>
                            <option value="EEE">EEE</option>
                            <option value="Civil">Civil</option>
                            <option value="CSBS">CSBS</option>
                            <option value="AIDS">AIDS</option>
                            <option value="Bio Tech">Bio Tech</option>
                            <option value="IT">IT</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full py-2 bg-gradient-to-tr from-purple-600 to-cyan-400 text-white font-bold rounded-xl transition">
                        Create Staff Credentials
                    </button>
                </form>
            </div>

            <!-- Staff List Table -->
            <div class="lg:col-span-2 admin-card rounded-2xl overflow-hidden h-fit">
                <div class="px-6 py-4 border-b border-white/5 bg-white/5">
                    <h3 class="heading-font text-xs sm:text-sm font-bold text-white uppercase">Staff Accounts Registry</h3>
                </div>
                <div class="overflow-x-auto text-[10px] sm:text-xs">
                    <table class="w-full text-left text-gray-300 min-w-[300px]">
                        <thead class="bg-black/40 border-b border-white/5 text-gray-400 font-mono">
                            <tr>
                                <th class="px-4 py-3">Staff Email</th>
                                <th class="px-4 py-3">Department</th>
                                <th class="px-4 py-3 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <% if (staff && staff.length > 0) { %>
                                <% staff.forEach(item => { %>
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="px-4 py-4 font-semibold text-white"><%= item.email %></td>
                                        <td class="px-4 py-4 font-mono text-purple-300"><%= item.department %></td>
                                        <td class="px-4 py-4 text-right font-mono">
                                            <a href="/admin/staff/delete/<%= item.id %>" onclick="return confirm('Permanently delete this staff account?');" class="text-red-400">Delete</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="3" class="px-4 py-8 text-center text-gray-500 font-mono">No staff accounts registered.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ========================================================================
             TAB 6: SEND EMAIL ANNOUNCEMENTS
             ======================================================================== -->
        <div id="tab-notify" class="admin-tab-content hidden max-w-xl mx-auto admin-card p-6 rounded-2xl mb-12">
            <h2 class="heading-font text-xs sm:text-sm font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-6 uppercase">
                Send Announcement Email
            </h2>
            <form action="/admin/notify" method="POST" class="space-y-4 text-xs">
                <!-- Dropdown selector added for independent group announcements -->
                <div>
                    <label class="block text-gray-400 font-mono mb-1">RECIPIENT GROUP</label>
                    <select name="recipientGroup" required class="w-full bg-[#130d24] border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none focus:border-cyan-400 transition">
                        <option value="student">All Registered Students</option>
                        <option value="staff">All Registered Staff</option>
                    </select>
                </div>
                <div>
                    <label class="block text-gray-400 font-mono mb-1">EMAIL SUBJECT</label>
                    <input type="text" name="subject" required placeholder="e.g., Academic Block Announcement" class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none">
                </div>
                <div>
                    <label class="block text-gray-400 font-mono mb-1">MESSAGE BODY</label>
                    <textarea name="message" required rows="10" placeholder="Type the announcement details here..." class="w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2 text-white focus:outline-none"></textarea>
                </div>
                <button type="submit" class="w-full py-2 bg-gradient-to-tr from-cyan-500 to-purple-600 text-white font-bold rounded-xl transition">
                    Dispatch Email Announcement
                </button>
            </form>
        </div>

        <!-- Secured Student Telemetry Table -->
        <div class="admin-card rounded-2xl overflow-hidden mt-12">
            <div class="px-6 py-4 border-b border-white/5 bg-white/5">
                <h2 class="heading-font text-xs sm:text-sm font-bold text-white uppercase">V.S.B. Registered Student Accounts</h2>
            </div>
            <div class="overflow-x-auto text-[10px] sm:text-xs">
                <table class="w-full text-left text-gray-300 min-w-[700px]">
                    <thead class="uppercase text-gray-400 tracking-wider bg-black/40 border-b border-white/5 font-mono">
                        <tr>
                            <th class="px-4 sm:px-6 py-4">System ID</th>
                            <th class="px-4 sm:px-6 py-4">Student Email</th>
                            <th class="px-4 sm:px-6 py-4">Year</th> 
                            <th class="px-4 sm:px-6 py-4">Department</th> 
                            <th class="px-4 sm:px-6 py-4">Database Access Role</th>
                            <th class="px-4 sm:px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% if (students && students.length > 0) { %>
                            <% students.forEach(student => { %>
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="px-4 sm:px-6 py-4 font-mono text-cyan-400"><%= student.id %></td>
                                    <td class="px-4 sm:px-6 py-4 text-white font-medium"><%= student.email %></td>
                                    <td class="px-4 sm:px-6 py-4 text-gray-300"><%= student.year %></td> 
                                    <td class="px-4 sm:px-6 py-4 text-gray-300"><%= student.department %></td> 
                                    <td class="px-4 sm:px-6 py-4">
                                        <span class="px-2 py-0.5 bg-blue-900/40 border border-blue-500/20 text-blue-300 rounded-full font-mono">
                                            <%= student.role %>
                                        </span>
                                    </td>
                                    <td class="px-4 sm:px-6 py-4 text-right font-mono whitespace-nowrap">
                                        <a href="/admin/students/delete/<%= student.id %>" onclick="return confirm('Are you sure you want to permanently delete this student account? This will block their sign-in.');" class="text-red-400 hover:text-red-300 transition">Delete</a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="px-4 sm:px-6 py-8 text-center text-gray-500 font-mono">No verified students registered on this database interface.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- Active Tracker script -->
    <script>
        const cursor = document.getElementById('cursor-core');
        document.addEventListener('mousemove', (e) => {
            if (window.innerWidth > 640) {
                cursor.style.left = `${e.clientX}px`;
                cursor.style.top = `${e.clientY}px`;
            }
        });

        // Tabbed Panel controller
        function switchAdminTab(targetTabId) {
            // Hide all tab content
            document.querySelectorAll('.admin-tab-content').forEach(tab => {
                tab.classList.add('hidden');
            });

            // Reset all tab button borders & colors
            document.querySelectorAll('[id^="btn-tab-"]').forEach(btn => {
                btn.classList.remove('border-cyan-400', 'text-white');
                btn.classList.add('border-transparent', 'text-gray-400');
            });

            // Show current active tab
            document.getElementById(targetTabId).classList.remove('hidden');

            // Highlight current active tab button
            document.getElementById('btn-tab-' + targetTabId.replace('tab-', '')).classList.add('border-cyan-400', 'text-white');
        }

        // --- EXCEL/CSV SHEET EXPORTER LOGIC ---
        function exportRegistrationsToCSV() {
            const rows = [["Pass ID (Ticket ID)", "Visitor Name", "Email Address", "Registered Event", "Academic Year", "Department", "College of Origin", "Registration Timestamp"]];
            
            // Collect each row from table body
            const tableRows = document.querySelectorAll('#registrations-table-body tr');
            
            tableRows.forEach(tr => {
                const cells = tr.querySelectorAll('td');
                if (cells.length > 0) {
                    const rowData = [
                        cells[0].innerText.trim(), // Ticket ID
                        cells[1].innerText.trim(), // Name
                        cells[2].innerText.trim(), // Email
                        cells[3].innerText.trim(), // Event Name
                        cells[4].innerText.trim(), // Year (hidden in UI table, but in DOM)
                        cells[5].innerText.trim(), // Department (hidden in UI table, but in DOM)
                        cells[6].innerText.trim(), // College (hidden in UI table, but in DOM)
                        cells[7].innerText.trim()  // Timestamp (hidden in UI table, but in DOM)
                    ];
                    rows.push(rowData);
                }
            });

            let csvContent = "data:text/csv;charset=utf-8,";
            
            rows.forEach(row => {
                // Escape quotes and format cells securely
                const escapedRow = row.map(val => `"${val.replace(/"/g, '""')}"`);
                csvContent += escapedRow.join(",") + "\r\n";
            });

            // Dispatch download trigger
            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", "VSB_AIML_Event_Registrations.csv");
            document.body.appendChild(link);
            
            link.click();
            document.body.removeChild(link);
        }

        // Active URL Query check (Allows direct redirect and landing onto correct tab)
        window.addEventListener('load', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const tabParam = urlParams.get('tab');
            if (tabParam === 'registrations') {
                switchAdminTab('tab-registrations');
            }
        });
    </script>
</body>
</html>